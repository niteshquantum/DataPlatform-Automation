<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="001-create-customers" author="automation">

        <preConditions onFail="MARK_RAN">

            <not>

                <tableExists
                        schemaName="public"
                        tableName="customers"/>

            </not>

        </preConditions>

        <createTable
                schemaName="public"
                tableName="customers">

            <column
                    name="customer_id"
                    type="SERIAL">

                <constraints
                        primaryKey="true"
                        nullable="false"/>

            </column>

            <column
                    name="customer_name"
                    type="VARCHAR(255)"/>

            <column
                    name="email"
                    type="VARCHAR(255)"/>

            <column
                    name="city"
                    type="VARCHAR(100)"/>

        </createTable>

    </changeSet>

</databaseChangeLog>