<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="007" author="tanisha">

        <preConditions onFail="MARK_RAN">

            <not>
                <tableExists
                    schemaName="public"
                    tableName="order_status"/>
            </not>

        </preConditions>

        <createTable
            schemaName="public"
            tableName="order_status">


        <column name="History_Log_ID" type="VARCHAR(255)"/>

        <column name="Order_ID" type="VARCHAR(255)"/>

        <column name="Lifecycle_Stage" type="VARCHAR(255)"/>

        <column name="Status_Change_Timestamp" type="VARCHAR(255)"/>

        <column name="Dispatch_Hub_ID" type="VARCHAR(255)"/>

        <column name="Delivery_Partner_ID" type="VARCHAR(255)"/>

        <column name="Route_Exception_Flag" type="VARCHAR(255)"/>

        <column name="Technical_Notes" type="VARCHAR(255)"/>

        <column name="created_at" type="VARCHAR(255)"/>

        <column name="updated_at" type="VARCHAR(255)"/>

        <column name="source_system" type="VARCHAR(255)"/>

        <column name="etl_load_timestamp" type="VARCHAR(255)"/>

        <column name="record_version" type="VARCHAR(255)"/>

        <column name="is_active" type="VARCHAR(255)"/>


        </createTable>

    </changeSet>

</databaseChangeLog>
