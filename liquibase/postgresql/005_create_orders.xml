<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="005" author="tanisha">

        <preConditions onFail="MARK_RAN">

            <not>
                <tableExists
                    schemaName="public"
                    tableName="orders"/>
            </not>

        </preConditions>

        <createTable
            schemaName="public"
            tableName="orders">


        <column name="Order_ID" type="VARCHAR(255)"/>

        <column name="Customer_ID" type="VARCHAR(255)"/>

        <column name="Order_Placed_Timestamp" type="VARCHAR(255)"/>

        <column name="Promised_Delivery_Timestamp" type="VARCHAR(255)"/>

        <column name="Days_Since_Prior_Order" type="VARCHAR(255)"/>

        <column name="Purchase_Channel_Type" type="VARCHAR(255)"/>

        <column name="Order_Status_Code" type="VARCHAR(255)"/>

        <column name="Global_Currency" type="VARCHAR(255)"/>

        <column name="Base_Basket_Amount" type="VARCHAR(255)"/>

        <column name="Shipping_Fee" type="VARCHAR(255)"/>

        <column name="Tax_Component" type="VARCHAR(255)"/>

        <column name="Total_Invoice_Value_USD" type="VARCHAR(255)"/>

        <column name="Total_Items_Ordered" type="VARCHAR(255)"/>

        <column name="created_at" type="VARCHAR(255)"/>

        <column name="updated_at" type="VARCHAR(255)"/>

        <column name="etl_load_timestamp" type="VARCHAR(255)"/>

        <column name="record_version" type="VARCHAR(255)"/>

        <column name="is_active" type="VARCHAR(255)"/>


        </createTable>

    </changeSet>

</databaseChangeLog>
