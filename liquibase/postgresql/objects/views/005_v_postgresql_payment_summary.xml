<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="005_v_postgresql_payment_summary" author="tanisha">

        <preConditions onFail="MARK_RAN">
            <not>
                <viewExists schemaName="public" viewName="v_postgresql_payment_summary"/>
            </not>
        </preConditions>

        <createView schemaName="public" viewName="v_postgresql_payment_summary">
            SELECT
                "Payment_ID",
                "Order_ID",
                "Payment_Sequential_Installment",
                "Payment_Method_Type",
                "Payment_Provider_Gateway",
                "Payment_Region",
                "Transacted_Amount_USD",
                "Settlement_Timestamp",
                "Auth_Response_Code",
                "Fraud_Risk_Score"
            FROM public.payments
        </createView>

    </changeSet>

</databaseChangeLog>
