<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="001_v_postgresql_customer_address" author="tanisha">

        <preConditions onFail="MARK_RAN">
            <not>
                <viewExists schemaName="public" viewName="v_postgresql_customer_address"/>
            </not>
        </preConditions>

        <createView schemaName="public" viewName="v_postgresql_customer_address">
            SELECT
                customer_id,
                street,
                city,
                state,
                country,
                postal_code,
                landmark,
                latitude,
                longitude,
                address_type,
                is_default,
                created_at
            FROM public.addresses
        </createView>

    </changeSet>

</databaseChangeLog>
