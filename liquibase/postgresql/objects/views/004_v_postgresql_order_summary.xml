<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="004_v_postgresql_order_summary" author="tanisha">

        <preConditions onFail="MARK_RAN">
            <not>
                <viewExists schemaName="public" viewName="v_postgresql_order_summary"/>
            </not>
        </preConditions>

        <createView schemaName="public" viewName="v_postgresql_order_summary">
            SELECT
                "Order_ID",
                "Customer_ID",
                "Order_Placed_Timestamp",
                "Promised_Delivery_Timestamp",
                "Purchase_Channel_Type",
                "Order_Status_Code",
                "Global_Currency",
                "Base_Basket_Amount",
                "Shipping_Fee",
                "Tax_Component",
                "Total_Invoice_Value_USD",
                "Total_Items_Ordered",
                created_at,
                updated_at
            FROM public.orders
        </createView>

    </changeSet>

</databaseChangeLog>
