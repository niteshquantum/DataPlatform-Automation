<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="003" author="tanisha">

        <preConditions onFail="MARK_RAN">

            <not>
                <tableExists
                    schemaName="public"
                    tableName="deals"/>
            </not>

        </preConditions>

        <createTable
            schemaName="public"
            tableName="deals">


        <column name="Deal_ID" type="VARCHAR(255)"/>

        <column name="Seller_ID" type="VARCHAR(255)"/>

        <column name="MQL_ID" type="VARCHAR(255)"/>

        <column name="Won_Date" type="VARCHAR(255)"/>

        <column name="Sdr_Operator_ID" type="VARCHAR(255)"/>

        <column name="Sr_Executive_ID" type="VARCHAR(255)"/>

        <column name="Lead_Type" type="VARCHAR(255)"/>

        <column name="Lead_Behavior_Segment" type="VARCHAR(255)"/>

        <column name="Origin_Channel_Source" type="VARCHAR(255)"/>

        <column name="created_at" type="VARCHAR(255)"/>

        <column name="updated_at" type="VARCHAR(255)"/>

        <column name="source_system" type="VARCHAR(255)"/>

        <column name="etl_load_timestamp" type="VARCHAR(255)"/>

        <column name="record_version" type="VARCHAR(255)"/>

        <column name="is_active" type="VARCHAR(255)"/>


        </createTable>

    </changeSet>

</databaseChangeLog>
