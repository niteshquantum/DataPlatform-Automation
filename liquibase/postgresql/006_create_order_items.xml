<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="006" author="tanisha">

        <preConditions onFail="MARK_RAN">

            <not>
                <tableExists
                    schemaName="public"
                    tableName="order_items"/>
            </not>

        </preConditions>

        <createTable
            schemaName="public"
            tableName="order_items">


        <column name="Item_Split_ID" type="VARCHAR(255)"/>

        <column name="Order_ID" type="VARCHAR(255)"/>

        <column name="Product_ID" type="VARCHAR(255)"/>

        <column name="Seller_ID" type="VARCHAR(255)"/>

        <column name="Quantity_Ordered" type="VARCHAR(255)"/>

        <column name="Add_To_Cart_Order" type="VARCHAR(255)"/>

        <column name="Original_Unit_Price" type="VARCHAR(255)"/>

        <column name="Net_Selling_Price" type="VARCHAR(255)"/>

        <column name="Promotional_Discount_Applied" type="VARCHAR(255)"/>

        <column name="Item_Tax_Amount" type="VARCHAR(255)"/>

        <column name="Fulfillment_Warehouse_Node" type="VARCHAR(255)"/>

        <column name="Packing_Status_Code" type="VARCHAR(255)"/>

        <column name="created_at" type="VARCHAR(255)"/>

        <column name="updated_at" type="VARCHAR(255)"/>

        <column name="source_system" type="VARCHAR(255)"/>

        <column name="etl_load_timestamp" type="VARCHAR(255)"/>

        <column name="record_version" type="VARCHAR(255)"/>

        <column name="is_active" type="VARCHAR(255)"/>


        </createTable>

    </changeSet>

</databaseChangeLog>
