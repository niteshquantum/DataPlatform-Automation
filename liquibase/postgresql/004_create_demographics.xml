<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="004" author="tanisha">

        <preConditions onFail="MARK_RAN">

            <not>
                <tableExists
                    schemaName="public"
                    tableName="demographics"/>
            </not>

        </preConditions>

        <createTable
            schemaName="public"
            tableName="demographics">


        <column name="customer_id" type="VARCHAR(255)"/>

        <column name="income_bracket" type="VARCHAR(255)"/>

        <column name="education" type="VARCHAR(255)"/>

        <column name="occupation" type="VARCHAR(255)"/>

        <column name="marital_status" type="VARCHAR(255)"/>

        <column name="nationality" type="VARCHAR(255)"/>

        <column name="lifestyle_type" type="VARCHAR(255)"/>

        <column name="city_tier" type="VARCHAR(255)"/>

        <column name="shopping_frequency" type="VARCHAR(255)"/>

        <column name="preferred_time" type="VARCHAR(255)"/>

        <column name="payment_reliability" type="VARCHAR(255)"/>

        <column name="dob" type="VARCHAR(255)"/>

        <column name="created_at" type="VARCHAR(255)"/>


        </createTable>

    </changeSet>

</databaseChangeLog>
