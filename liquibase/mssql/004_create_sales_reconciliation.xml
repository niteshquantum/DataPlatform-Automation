<?xml version="1.0" encoding="UTF-8"?>
 
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">
 
    <changeSet id="004" author="tanisha">
 
    <preConditions onFail="MARK_RAN">
        <not>
            <tableExists tableName="sales_reconciliation"/>
        </not>
    </preConditions>
 
    <createTable tableName="sales_reconciliation">

        <column name="Export_Log_ID" type="VARCHAR(255)"/>

        <column name="Reporting_Date" type="VARCHAR(255)"/>

        <column name="Settlement_Cycle_Code" type="VARCHAR(255)"/>

        <column name="Gross_Sales_Volume" type="VARCHAR(255)"/>

        <column name="Total_COGS" type="VARCHAR(255)"/>

        <column name="Tax_Component" type="VARCHAR(255)"/>

        <column name="Net_Profit_Amount" type="VARCHAR(255)"/>

        <column name="Corporate_Tax_Zone" type="VARCHAR(255)"/>

        <column name="Reconciliation_Match_Flag" type="VARCHAR(255)"/>

        <column name="Last_Sync_Timestamp" type="VARCHAR(255)"/>

        <column name="created_at" type="VARCHAR(255)"/>

        <column name="updated_at" type="VARCHAR(255)"/>

        <column name="source_system" type="VARCHAR(255)"/>

        <column name="etl_load_timestamp" type="VARCHAR(255)"/>

        <column name="record_version" type="VARCHAR(255)"/>

        <column name="is_active" type="VARCHAR(255)"/>

        </createTable>
 
    </changeSet>
 
</databaseChangeLog>
