<?xml version="1.0" encoding="UTF-8"?>
 
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">
 
    <changeSet id="002" author="tanisha">
 
    <preConditions onFail="MARK_RAN">
        <not>
            <tableExists tableName="customer_sessions"/>
        </not>
    </preConditions>
 
    <createTable tableName="customer_sessions">

        <column name="session_id" type="VARCHAR(255)"/>

        <column name="customer_id" type="VARCHAR(255)"/>

        <column name="login_time" type="VARCHAR(255)"/>

        <column name="logout_time" type="VARCHAR(255)"/>

        <column name="device_used" type="VARCHAR(255)"/>

        <column name="browser" type="VARCHAR(255)"/>

        <column name="pages_visited" type="VARCHAR(255)"/>

        <column name="channel" type="VARCHAR(255)"/>

        <column name="ip_address" type="VARCHAR(255)"/>

        </createTable>
 
    </changeSet>
 
</databaseChangeLog>
