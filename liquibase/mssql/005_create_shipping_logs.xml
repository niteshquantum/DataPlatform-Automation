<?xml version="1.0" encoding="UTF-8"?>
 
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">
 
    <changeSet id="005" author="tanisha">
 
    <preConditions onFail="MARK_RAN">
        <not>
            <tableExists tableName="shipping_logs"/>
        </not>
    </preConditions>
 
    <createTable tableName="shipping_logs">

        <column name="Manifest_ID" type="VARCHAR(255)"/>

        <column name="Order_ID" type="VARCHAR(255)"/>

        <column name="Carrier_Enterprise_Name" type="VARCHAR(255)"/>

        <column name="Service_Class_Tier" type="VARCHAR(255)"/>

        <column name="Tracking_Number" type="VARCHAR(255)"/>

        <column name="Destination_Postal_Zip_Code" type="VARCHAR(255)"/>

        <column name="Parcel_Dimensions_String" type="VARCHAR(255)"/>

        <column name="Freight_Class_Code" type="VARCHAR(255)"/>

        <column name="Transit_ETA_Hours" type="VARCHAR(255)"/>

        <column name="created_at" type="VARCHAR(255)"/>

        <column name="updated_at" type="VARCHAR(255)"/>

        <column name="source_system" type="VARCHAR(255)"/>

        <column name="etl_load_timestamp" type="VARCHAR(255)"/>

        <column name="record_version" type="VARCHAR(255)"/>

        <column name="is_active" type="VARCHAR(255)"/>

        </createTable>
 
    </changeSet>
 
</databaseChangeLog>
