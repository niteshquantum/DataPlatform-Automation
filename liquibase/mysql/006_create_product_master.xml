<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="006" author="tanisha">

    <preConditions onFail="MARK_RAN">
        <not>
            <tableExists tableName="product_master"/>
        </not>
    </preConditions>

    <createTable tableName="product_master">

        <column name="Product_ID" type="VARCHAR(255)"/>

        <column name="SKU" type="VARCHAR(255)"/>

        <column name="Title" type="VARCHAR(255)"/>

        <column name="Brand_ID" type="VARCHAR(255)"/>

        <column name="Category_ID" type="VARCHAR(255)"/>

        <column name="Subcategory_ID" type="VARCHAR(255)"/>

        <column name="Short_Description" type="VARCHAR(255)"/>

        <column name="Long_Description" type="VARCHAR(255)"/>

        <column name="Model_Number" type="VARCHAR(255)"/>

        <column name="Manufacturer" type="VARCHAR(255)"/>

        <column name="Warranty_Months" type="VARCHAR(255)"/>

        <column name="Launch_Date" type="VARCHAR(255)"/>

        <column name="Discontinued_Date" type="VARCHAR(255)"/>

        <column name="Style" type="VARCHAR(255)"/>

        <column name="Is_Active" type="VARCHAR(255)"/>

        <column name="Created_At" type="VARCHAR(255)"/>

        <column name="Updated_At" type="VARCHAR(255)"/>

        </createTable>

    </changeSet>

</databaseChangeLog>
