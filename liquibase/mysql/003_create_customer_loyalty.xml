<?xml version="1.0" encoding="UTF-8"?>
 
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">
 
    <changeSet id="003" author="tanisha">
 
    <preConditions onFail="MARK_RAN">
        <not>
            <tableExists tableName="customer_loyalty"/>
        </not>
    </preConditions>
 
    <createTable tableName="customer_loyalty">

        <column name="customer_id" type="VARCHAR(255)"/>

        <column name="loyalty_tier" type="VARCHAR(255)"/>

        <column name="points_balance" type="VARCHAR(255)"/>

        <column name="total_spent" type="VARCHAR(255)"/>

        <column name="member_since" type="VARCHAR(255)"/>

        <column name="last_activity_date" type="VARCHAR(255)"/>

        <column name="referral_count" type="VARCHAR(255)"/>

        <column name="cashback_earned" type="VARCHAR(255)"/>

        <column name="reward_expiry_date" type="VARCHAR(255)"/>

        </createTable>
 
    </changeSet>
 
</databaseChangeLog>
