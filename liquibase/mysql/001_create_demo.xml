<?xml version="1.0" encoding="UTF-8"?>
 
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">
 
    <changeSet id="001" author="tanisha">
 
    <preConditions onFail="MARK_RAN">
        <not>
            <tableExists tableName="demo"/>
        </not>
    </preConditions>
 
    <createTable tableName="demo">

        <column name="Employee_ID" type="VARCHAR(255)"/>

        <column name="Full_Name" type="VARCHAR(255)"/>

        <column name="Department" type="VARCHAR(255)"/>

        <column name="Join_Date" type="VARCHAR(255)"/>

        <column name="Salary_INR" type="VARCHAR(255)"/>

        <column name="Rating" type="VARCHAR(255)"/>

        </createTable>
 
    </changeSet>
 
</databaseChangeLog>
