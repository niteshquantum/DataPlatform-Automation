<?xml version="1.0" encoding="UTF-8"?>
 
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">
 
    <changeSet id="009" author="tanisha">
 
    <preConditions onFail="MARK_RAN">
        <not>
            <tableExists tableName="support_tickets"/>
        </not>
    </preConditions>
 
    <createTable tableName="support_tickets">

        <column name="ticket_id" type="VARCHAR(255)"/>

        <column name="customer_id" type="VARCHAR(255)"/>

        <column name="issue_type" type="VARCHAR(255)"/>

        <column name="status" type="VARCHAR(255)"/>

        <column name="priority" type="VARCHAR(255)"/>

        <column name="created_at" type="VARCHAR(255)"/>

        <column name="resolved_at" type="VARCHAR(255)"/>

        <column name="agent_id" type="VARCHAR(255)"/>

        <column name="resolution_notes" type="VARCHAR(255)"/>

        </createTable>
 
    </changeSet>
 
</databaseChangeLog>
