<?xml version="1.0" encoding="UTF-8"?>
 
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">
 
    <changeSet id="001" author="tanisha">
 
    <preConditions onFail="MARK_RAN">
        <not>
            <tableExists tableName="brands"/>
        </not>
    </preConditions>
 
    <createTable tableName="brands">

        <column name="Brand_ID" type="VARCHAR(255)"/>

        <column name="Brand_Name" type="VARCHAR(255)"/>

        <column name="Parent_Company" type="VARCHAR(255)"/>

        <column name="Brand_Origin_Country" type="VARCHAR(255)"/>

        <column name="Brand_Established_Year" type="VARCHAR(255)"/>

        <column name="Brand_Tier" type="VARCHAR(255)"/>

        <column name="Brand_Status" type="VARCHAR(255)"/>

        <column name="Brand_Support_Email" type="VARCHAR(255)"/>

        <column name="Brand_Support_Phone" type="VARCHAR(255)"/>

        <column name="Brand_Website_URL" type="VARCHAR(255)"/>

        </createTable>
 
    </changeSet>
 
</databaseChangeLog>
