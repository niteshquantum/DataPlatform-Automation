<?xml version="1.0" encoding="UTF-8"?>
 
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">
 
    <changeSet id="004" author="tanisha">
 
    <preConditions onFail="MARK_RAN">
        <not>
            <tableExists tableName="inventory"/>
        </not>
    </preConditions>
 
    <createTable tableName="inventory">

        <column name="Inventory_ID" type="VARCHAR(255)"/>

        <column name="Product_ID" type="VARCHAR(255)"/>

        <column name="SKU" type="VARCHAR(255)"/>

        <column name="Total_Stock" type="VARCHAR(255)"/>

        <column name="Reserved_Stock" type="VARCHAR(255)"/>

        <column name="Available_Stock" type="VARCHAR(255)"/>

        <column name="On_Order_Qty" type="VARCHAR(255)"/>

        <column name="Backorder_Qty" type="VARCHAR(255)"/>

        <column name="Reorder_Point" type="VARCHAR(255)"/>

        <column name="Safety_Stock_Limit" type="VARCHAR(255)"/>

        <column name="Warehouse_ID" type="VARCHAR(255)"/>

        <column name="Warehouse_Name" type="VARCHAR(255)"/>

        <column name="Aisle_No" type="VARCHAR(255)"/>

        <column name="Bin_Location" type="VARCHAR(255)"/>

        <column name="Shelf_Level" type="VARCHAR(255)"/>

        <column name="Zone_Code" type="VARCHAR(255)"/>

        <column name="Stock_Status" type="VARCHAR(255)"/>

        <column name="Last_Stock_Count_Date" type="VARCHAR(255)"/>

        <column name="Cycle_Count_Frequency" type="VARCHAR(255)"/>

        </createTable>
 
    </changeSet>
 
</databaseChangeLog>
