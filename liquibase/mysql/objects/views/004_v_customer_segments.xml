<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="004_v_customer_segments" author="tanisha">

        <preConditions onFail="MARK_RAN">
            <not>
                <viewExists viewName="v_customer_segments"/>
            </not>
        </preConditions>

        <createView viewName="v_customer_segments">
            SELECT
                CONCAT('SEG', customer_id) AS segment_id,
                customer_id,
                NULL AS rfm_score,
                NULL AS recency_days,
                referral_count AS frequency_count,
                total_spent AS monetary_value,
                NULL AS churn_risk_score,
                loyalty_tier AS segment_label,
                last_activity_date AS computed_at
            FROM customer_loyalty
        </createView>

    </changeSet>

</databaseChangeLog>
