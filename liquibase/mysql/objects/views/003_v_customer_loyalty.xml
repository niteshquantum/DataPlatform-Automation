<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="003_v_customer_loyalty" author="tanisha">

        <preConditions onFail="MARK_RAN">
            <not>
                <viewExists viewName="v_customer_loyalty"/>
            </not>
        </preConditions>

        <createView viewName="v_customer_loyalty">
            SELECT
                customer_id,
                loyalty_tier,
                points_balance,
                total_spent,
                member_since,
                last_activity_date,
                referral_count,
                cashback_earned,
                reward_expiry_date
            FROM customer_loyalty
        </createView>

    </changeSet>

</databaseChangeLog>
