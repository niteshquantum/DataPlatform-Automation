<?xml version="1.0" encoding="UTF-8"?>

<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="005_v_customer_support_tickets" author="tanisha">

        <preConditions onFail="MARK_RAN">
            <not>
                <viewExists viewName="v_customer_support_tickets"/>
            </not>
        </preConditions>

        <createView viewName="v_customer_support_tickets">
            SELECT
                ticket_id,
                customer_id,
                issue_type,
                status,
                priority,
                created_at,
                resolved_at,
                agent_id,
                resolution_notes
            FROM support_tickets
        </createView>

    </changeSet>

</databaseChangeLog>
