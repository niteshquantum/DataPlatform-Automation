<?xml version="1.0" encoding="UTF-8"?>
 
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">
 
    <changeSet id="005" author="tanisha">
 
    <preConditions onFail="MARK_RAN">
        <not>
            <tableExists tableName="price_history"/>
        </not>
    </preConditions>
 
    <createTable tableName="price_history">

        <column name="Product_ID" type="VARCHAR(255)"/>

        <column name="Effective_Date" type="VARCHAR(255)"/>

        <column name="MRP" type="VARCHAR(255)"/>

        <column name="Cost_Price" type="VARCHAR(255)"/>

        <column name="Selling_Price" type="VARCHAR(255)"/>

        <column name="Discount_Percentage" type="VARCHAR(255)"/>

        <column name="Is_Sale_Price" type="VARCHAR(255)"/>

        <column name="Season_Tag" type="VARCHAR(255)"/>

        <column name="Price_Change_Reason" type="VARCHAR(255)"/>

        <column name="Sale_Start_Date" type="VARCHAR(255)"/>

        <column name="Sale_End_Date" type="VARCHAR(255)"/>

        </createTable>
 
    </changeSet>
 
</databaseChangeLog>
