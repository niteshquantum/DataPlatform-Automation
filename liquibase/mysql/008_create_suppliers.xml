<?xml version="1.0" encoding="UTF-8"?>
 
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">
 
    <changeSet id="008" author="tanisha">
 
    <preConditions onFail="MARK_RAN">
        <not>
            <tableExists tableName="suppliers"/>
        </not>
    </preConditions>
 
    <createTable tableName="suppliers">

        <column name="Supplier_ID" type="VARCHAR(255)"/>

        <column name="Supplier_Name" type="VARCHAR(255)"/>

        <column name="Supplier_Rating" type="VARCHAR(255)"/>

        <column name="Country" type="VARCHAR(255)"/>

        <column name="Is_Active" type="VARCHAR(255)"/>

        </createTable>
 
    </changeSet>
 
</databaseChangeLog>
