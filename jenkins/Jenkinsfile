                            initializeLogging('postgresql', 'load', 'windows')
                        }
                    }
                }

                stage('PostgreSQL Load - Validate Python Runtime') {
                    steps {
                        script {
                            runTrackedStage('postgresql', 'load', 'Validate Python Runtime') {
                                bat 'scripts\\batch\\common\\validate_python_runtime.bat'
                            }
                        }
                    }
                }

                stage('PostgreSQL Load - Validate Python Requirements') {
                    steps {
                        script {
                            runTrackedStage('postgresql', 'load', 'Validate Python Requirements') {
                                bat 'scripts\\batch\\postgresql\\setup\\validate_python_requirements.bat'
                            }
                        }
                    }
                }

                stage('PostgreSQL Load - Start PostgreSQL') {
