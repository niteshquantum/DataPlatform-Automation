                            }
                        }
                    }
                }


                stage('MongoDB Setup - Install Python Requirements') {

                    steps {

                        script {

                            runTrackedStage(
                                'mongodb',
                                'setup',
                                'Install Python Requirements'
                            ) {

                                bat 'scripts\\batch\\mongodb\\setup\\install_python_requirements.bat'
                            }
                        }
                    }
                }


                stage('MongoDB Setup - Validate Python Requirements') {

                    steps {

                        script {

                            runTrackedStage(
                                'mongodb',
                                'setup',
                                'Validate Python Requirements'
                            ) {

                                bat 'scripts\\batch\\mongodb\\setup\\validate_python_requirements.bat'
                            }
                        }
                    }
                }


                stage('MongoDB Setup - Validate Java Runtime') {

                    steps {

                        script {

                            runTrackedStage(
                                'mongodb',
                                'setup',
                                'Validate Java Runtime'
                            ) {

                                bat 'scripts\\batch\\common\\validate_java_runtime.bat'
                            }
                        }
                    }
                }


                stage('MongoDB Setup - Install Tools') {

                    steps {

                        script {

                            runTrackedStage(
                                'mongodb',
                                'setup',
                                'Install Tools'
                            ) {

                                bat 'scripts\\batch\\mongodb\\setup\\install_tools.bat'
                            }
                        }
                    }
                }


                stage('MongoDB Setup - Validate Tools') {

                    steps {

                        script {

                            runTrackedStage(
                                'mongodb',
                                'setup',
                                'Validate Tools'
                            ) {

                                bat 'scripts\\batch\\mongodb\\setup\\validate_tools.bat'
                            }
                        }
                    }
                }


                stage('MongoDB Setup - Deploy MongoDB') {

                    steps {

                        script {

                            runTrackedStage(
                                'mongodb',
                                'setup',
                                'Deploy MongoDB'
                            ) {

                                bat 'scripts\\batch\\mongodb\\setup\\run_terraform.bat'
                            }
                        }
                    }
                }


                stage('MongoDB Setup - Configure Global Mongosh') {

                    when {

                        expression {

                            return readFile(
                                'admin_status.txt'
                            ).trim() == 'true'
                        }
                    }


                    steps {

                        script {

                            runTrackedStage(
                                'mongodb',
                                'setup',
                                'Configure Global Mongosh'
                            ) {

                                echo 'Administrator privileges available.'
                                echo 'Configuring Global Mongosh command...'

                                bat 'scripts\\batch\\mongodb\\setup\\configure_global_mongosh.bat'
                            }
                        }
                    }
                }


                stage('MongoDB Setup - Configure MongoDB Service') {

                    when {

                        expression {

                            return readFile(
                                'admin_status.txt'
                            ).trim() == 'true'
                        }
                    }


                    steps {

                        script {

                            runTrackedStage(
                                'mongodb',
                                'setup',
                                'Configure MongoDB Service'
                            ) {

                                echo 'Administrator privileges available.'
                                echo 'Configuring MongoDB Windows Service...'

                                bat 'scripts\\batch\\mongodb\\setup\\configure_mongodb_service.bat'
                            }
                        }
                    }
                }


                stage('MongoDB Setup - Start MongoDB') {

                    when {

                        expression {

                            return readFile(
                                'admin_status.txt'
                            ).trim() != 'true'
                        }
                    }


                    steps {

                        script {

                            runTrackedStage(
                                'mongodb',
                                'setup',
                                'Start MongoDB'
                            ) {

                                echo 'Administrator privileges unavailable.'
                                echo 'Starting MongoDB in project-local mode...'

                                bat 'scripts\\batch\\mongodb\\setup\\start_mongodb.bat'
                            }
                        }
                    }
                }


                stage('MongoDB Setup - Validate MongoDB') {

                    steps {

                        script {

                            runTrackedStage(
                                'mongodb',
                                'setup',
                                'Validate MongoDB'
                            ) {

                                bat 'scripts\\batch\\mongodb\\setup\\validate_mongodb.bat'
                            }
                        }
                    }
                }
            }


            post {

                success {

                    script {

                        def adminResult = readFile(
                            'admin_status.txt'
                        ).trim()

                        if (adminResult == 'true') {

                            echo 'MongoDB Windows Service configured successfully.'
                            echo 'Global Mongosh configuration completed successfully.'

                        } else {

                            echo 'MongoDB configured successfully in project-local mode.'
                            echo 'Windows Service and Global Mongosh configuration were skipped because Administrator privileges were unavailable.'
                        }
                    }

                    echo 'MONGODB SETUP SUCCESSFUL'
                }


                failure {

                    echo 'MONGODB SETUP FAILED'
                }


                always {

                    script {

                        finalizeLoggingAndReporting(
                            'mongodb',
                            'setup',
                            currentBuild.currentResult
                        )
                    }

                    echo 'MONGODB SETUP PIPELINE COMPLETED'
                }
            }
        }



