/*
============================================================
COMMON EXECUTION FUNCTION
============================================================
*/

def runPipeline(
    String database,
    String action,
    String operatingSystem,
    Closure executionBody
) {

    def finalStatus = 'SUCCESS'

    try {

        /*
        ============================================================
        INITIALIZE LOGGING
        ============================================================
        */

        if (isUnix()) {

            sh """
                python3 scripts/logging/logger.py init \
                    --database ${database} \
                    --action ${action} \
                    --os ${operatingSystem} \
                    --build-number ${env.BUILD_NUMBER} \
                    --job-name "${env.JOB_NAME}" \
                    --build-url "${env.BUILD_URL}"
            """

        } else {

            bat """
                python scripts\\logging\\logger.py init ^
                    --database ${database} ^
                    --action ${action} ^
                    --os ${operatingSystem} ^
                    --build-number ${env.BUILD_NUMBER} ^
                    --job-name "${env.JOB_NAME}" ^
                    --build-url "${env.BUILD_URL}"
            """
        }


        /*
        ============================================================
        EXECUTE EXISTING PIPELINE
        ============================================================
        */

        executionBody()


    } catch (Exception error) {

        finalStatus = 'FAILURE'

        throw error

    } finally {

        /*
        ============================================================
        FINALIZE LOGGING
        ============================================================
        */

        if (isUnix()) {

            sh """
                python3 scripts/logging/logger.py finalize \
                    --database ${database} \
                    --action ${action} \
                    --build-number ${env.BUILD_NUMBER} \
                    --status ${finalStatus}
            """

        } else {

            bat """
                python scripts\\logging\\logger.py finalize ^
                    --database ${database} ^
                    --action ${action} ^
                    --build-number ${env.BUILD_NUMBER} ^
                    --status ${finalStatus}
            """
        }


        /*
        ============================================================
        GENERATE REPORT
        ============================================================
        */

        if (isUnix()) {

            sh """
                python3 scripts/reporting/generate_report.py \
                    --database ${database} \
                    --action ${action} \
                    --build-number ${env.BUILD_NUMBER}
            """

        } else {

            bat """
                python scripts\\reporting\\generate_report.py ^
                    --database ${database} ^
                    --action ${action} ^
                    --build-number ${env.BUILD_NUMBER}
            """
        }


        /*
        ============================================================
        ARCHIVE LOGS AND REPORTS
        ============================================================
        */

        archiveArtifacts(
            artifacts: """
                logs/${database}/${action}/build_${env.BUILD_NUMBER}/**,
                reports/${database}/${action}/build_${env.BUILD_NUMBER}/**,
                reports/history/**
            """.replaceAll("\\s+", ""),
            fingerprint: true,
            allowEmptyArchive: true
        )
    }
}


/*
============================================================
MASTER DATABASE PIPELINE
============================================================
*/

pipeline {

    agent none


    options {

        disableConcurrentBuilds()
    }


    parameters {

        choice(
            name: 'DATABASE',
            choices: [
                'MYSQL',
                'MSSQL',
                'MONGODB',
                'POSTGRESQL'
            ],
            description: 'Select Database'
        )


        choice(
            name: 'ACTION',
            choices: [
                'SETUP',
                'LOAD',
                'CLEANUP'
            ],
            description: 'Select Action'
        )


        choice(
            name: 'CLEANUP_MODE',
            choices: [
                'PRESERVE_DATA',
                'DELETE_DATA'
            ],
            description: 'Used only for Windows CLEANUP action'
        )
    }


    stages {


        /*
        ============================================================
        VALIDATE SELECTION
        ============================================================
        */

        stage('Validate Selection') {

            agent any


            steps {

                script {

                    if (
                        params.ACTION == 'CLEANUP' &&
                        (
                            params.DATABASE == 'MYSQL' ||
                            params.DATABASE == 'MSSQL'
                        )
                    ) {

                        error(
                            "CLEANUP is available only for Windows databases."
                        )
                    }


                    echo "============================================"
                    echo "DATABASE     : ${params.DATABASE}"
                    echo "ACTION       : ${params.ACTION}"
                    echo "CLEANUP MODE : ${params.CLEANUP_MODE}"
                    echo "============================================"
                }
            }
        }



        /*
        ============================================================
        MYSQL SETUP
        UBUNTU
        ============================================================
        */

        stage('MySQL Setup') {

            agent {
                label 'ubuntu-node'
            }


            when {

                allOf {

                    expression {
                        params.DATABASE == 'MYSQL'
                    }

                    expression {
                        params.ACTION == 'SETUP'
                    }
                }
            }


            steps {

                checkout scm


                script {

                    runPipeline(
                        'mysql',
                        'setup',
                        'ubuntu'
                    ) {

                        sh '''
                            find scripts/bash -type f -name "*.sh" -exec chmod +x {} \\;

                            ./scripts/bash/common/validate_python_runtime.sh
                            ./scripts/bash/common/validate_java_runtime.sh
                            ./scripts/bash/mysql/setup/install_tools.sh
                            ./scripts/bash/mysql/setup/install_mysql.sh
                            ./scripts/bash/mysql/setup/deploy_mysql.sh
                            ./scripts/bash/mysql/setup/start_mysql.sh
                            ./scripts/bash/mysql/setup/create_database.sh
                            ./scripts/bash/mysql/setup/configure_global_mysql.sh
                            ./scripts/bash/mysql/setup/validate_environment.sh
                        '''
                    }
                }
            }
        }



        /*
        ============================================================
        MYSQL LOAD
        UBUNTU
        ============================================================
        */

        stage('MySQL Load') {

            agent {
                label 'ubuntu-node'
            }


            when {

                allOf {

                    expression {
                        params.DATABASE == 'MYSQL'
                    }

                    expression {
                        params.ACTION == 'LOAD'
                    }
                }
            }


            steps {

                checkout scm


                script {

                    runPipeline(
                        'mysql',
                        'load',
                        'ubuntu'
                    ) {

                        sh '''
                            find scripts/bash -type f -name "*.sh" -exec chmod +x {} \\;

                            ./scripts/bash/common/validate_python_runtime.sh
                            ./scripts/bash/mysql/setup/install_python_requirements.sh
                            ./scripts/bash/mysql/setup/validate_python_requirements.sh
                            ./scripts/bash/mysql/setup/start_mysql.sh
                            ./scripts/bash/mysql/setup/validate_mysql.sh
                            ./scripts/bash/mysql/load/load_data.sh
                            ./scripts/bash/mysql/load/validate_loaded_data.sh
                        '''
                    }
                }
            }
        }



        /*
        ============================================================
        MSSQL SETUP
        UBUNTU
        ============================================================
        */

        stage('MSSQL Setup') {

            agent {
                label 'ubuntu-node'
            }


            when {

                allOf {

                    expression {
                        params.DATABASE == 'MSSQL'
                    }

                    expression {
                        params.ACTION == 'SETUP'
                    }
                }
            }


            steps {

                checkout scm


                script {

                    runPipeline(
                        'mssql',
                        'setup',
                        'ubuntu'
                    ) {

                        sh '''
                            chmod +x scripts/bash/common/*.sh
                            chmod +x scripts/bash/mssql/*.sh

                            ./scripts/bash/common/validate_python_runtime.sh
                            ./scripts/bash/common/validate_java_runtime.sh
                            ./scripts/bash/common/install_tools.sh
                            ./scripts/bash/common/install_mssql_driver.sh
                            ./scripts/bash/mssql/install_mssql.sh
                            ./scripts/bash/mssql/install_sqlcmd.sh
                            ./scripts/bash/mssql/start_mssql.sh
                            ./scripts/bash/mssql/create_database.sh
                            ./scripts/bash/mssql/run_liquibase.sh
                            ./scripts/bash/mssql/validate_environment.sh
                        '''
                    }
                }
            }
        }



        /*
        ============================================================
        MSSQL LOAD
        UBUNTU
        ============================================================
        */

        stage('MSSQL Load') {

            agent {
                label 'ubuntu-node'
            }


            when {

                allOf {

                    expression {
                        params.DATABASE == 'MSSQL'
                    }

                    expression {
                        params.ACTION == 'LOAD'
                    }
                }
            }


            steps {

                checkout scm


                script {

                    runPipeline(
                        'mssql',
                        'load',
                        'ubuntu'
                    ) {

                        sh '''
                            find scripts/bash -type f -name "*.sh" -exec chmod +x {} \\;

                            ./scripts/bash/common/validate_python_runtime.sh
                            ./scripts/bash/install_python_requirements.sh
                            ./scripts/bash/validate_python_requirements.sh
                            ./scripts/bash/common/install_tools.sh
                            ./scripts/bash/mssql/validate_tools.sh
                            ./scripts/bash/mssql/validate_mssql.sh
                            ./scripts/bash/mssql/load_data.sh
                            ./scripts/bash/mssql/validate_loaded_data.sh
                        '''
                    }
                }
            }
        }



        /*
        ============================================================
        MONGODB SETUP
        WINDOWS
        ============================================================
        */

        stage('MongoDB Setup') {

            agent {
                label 'windows-node'
            }


            when {

                allOf {

                    expression {
                        params.DATABASE == 'MONGODB'
                    }

                    expression {
                        params.ACTION == 'SETUP'
                    }
                }
            }


            steps {

                checkout scm


                script {

                    runPipeline(
                        'mongodb',
                        'setup',
                        'windows'
                    ) {

                        bat '''
                            scripts\\batch\\common\\validate_python_runtime.bat

                            scripts\\batch\\mongodb\\setup\\install_python_requirements.bat

                            scripts\\batch\\mongodb\\setup\\validate_python_requirements.bat

                            scripts\\batch\\common\\validate_java_runtime.bat

                            scripts\\batch\\mongodb\\setup\\install_tools.bat

                            scripts\\batch\\mongodb\\setup\\validate_tools.bat

                            scripts\\batch\\mongodb\\setup\\run_terraform.bat
                        '''


                        def adminStatus = bat(
                            script: 'scripts\\batch\\common\\check_admin_privileges.bat',
                            returnStatus: true
                        )


                        if (adminStatus == 0) {

                            echo 'Administrator privileges available.'

                            bat '''
                                scripts\\batch\\mongodb\\setup\\configure_global_mongosh.bat

                                scripts\\batch\\mongodb\\setup\\configure_mongodb_service.bat
                            '''

                        } else {

                            echo 'Administrator privileges unavailable.'

                            echo 'MongoDB will run in project-local mode.'

                            bat '''
                                scripts\\batch\\mongodb\\setup\\start_mongodb.bat
                            '''
                        }


                        bat '''
                            scripts\\batch\\mongodb\\setup\\validate_mongodb.bat
                        '''
                    }
                }
            }
        }



        /*
        ============================================================
        MONGODB LOAD
        WINDOWS
        ============================================================
        */

        stage('MongoDB Load') {

            agent {
                label 'windows-node'
            }


            when {

                allOf {

                    expression {
                        params.DATABASE == 'MONGODB'
                    }

                    expression {
                        params.ACTION == 'LOAD'
                    }
                }
            }


            steps {

                checkout scm


                script {

                    runPipeline(
                        'mongodb',
                        'load',
                        'windows'
                    ) {

                        bat '''
                            scripts\\batch\\common\\validate_python_runtime.bat

                            scripts\\batch\\mongodb\\setup\\validate_python_requirements.bat

                            scripts\\batch\\mongodb\\setup\\start_mongodb.bat

                            scripts\\batch\\mongodb\\setup\\validate_mongodb.bat

                            scripts\\batch\\common\\download_dataset.bat

                            scripts\\batch\\mongodb\\load\\load_data.bat

                            scripts\\batch\\mongodb\\load\\validate_loaded_data.bat
                        '''
                    }
                }
            }
        }



        /*
        ============================================================
        MONGODB CLEANUP
        WINDOWS
        ============================================================
        */

        stage('MongoDB Cleanup') {

            agent {
                label 'windows-node'
            }


            when {

                allOf {

                    expression {
                        params.DATABASE == 'MONGODB'
                    }

                    expression {
                        params.ACTION == 'CLEANUP'
                    }
                }
            }


            steps {

                checkout scm


                script {

                    runPipeline(
                        'mongodb',
                        'cleanup',
                        'windows'
                    ) {

                        withEnv([
                            "CLEANUP_MODE=${params.CLEANUP_MODE}"
                        ]) {

                            bat '''
                                scripts\\batch\\mongodb\\cleanup\\mongodb_cleanup_pipeline.bat
                            '''
                        }
                    }
                }
            }
        }



        /*
        ============================================================
        POSTGRESQL SETUP
        WINDOWS
        ============================================================
        */

        stage('PostgreSQL Setup') {

            agent {
                label 'windows-node'
            }


            when {

                allOf {

                    expression {
                        params.DATABASE == 'POSTGRESQL'
                    }

                    expression {
                        params.ACTION == 'SETUP'
                    }
                }
            }


            steps {

                checkout scm


                script {

                    runPipeline(
                        'postgresql',
                        'setup',
                        'windows'
                    ) {

                        bat '''
                            scripts\\batch\\common\\validate_python_runtime.bat

                            scripts\\batch\\postgresql\\setup\\install_python_requirements.bat

                            scripts\\batch\\postgresql\\setup\\validate_python_requirements.bat

                            scripts\\batch\\common\\validate_java_runtime.bat

                            scripts\\batch\\postgresql\\setup\\install_tools.bat

                            scripts\\batch\\postgresql\\setup\\deploy_postgresql.bat

                            scripts\\batch\\postgresql\\setup\\configure_postgresql_service.bat

                            scripts\\batch\\postgresql\\setup\\create_database.bat

                            scripts\\batch\\postgresql\\setup\\configure_global_psql.bat

                            scripts\\batch\\postgresql\\setup\\validate_environment.bat
                        '''
                    }
                }
            }
        }



        /*
        ============================================================
        POSTGRESQL LOAD
        WINDOWS
        ============================================================
        */

        stage('PostgreSQL Load') {

            agent {
                label 'windows-node'
            }


            when {

                allOf {

                    expression {
                        params.DATABASE == 'POSTGRESQL'
                    }

                    expression {
                        params.ACTION == 'LOAD'
                    }
                }
            }


            steps {

                checkout scm


                script {

                    runPipeline(
                        'postgresql',
                        'load',
                        'windows'
                    ) {

                        bat '''
                            scripts\\batch\\common\\validate_python_runtime.bat

                            scripts\\batch\\postgresql\\setup\\validate_python_requirements.bat

                            scripts\\batch\\postgresql\\setup\\start_postgresql.bat

                            scripts\\batch\\postgresql\\setup\\validate_postgresql.bat

                            scripts\\batch\\postgresql\\load\\load_data.bat

                            scripts\\batch\\postgresql\\load\\validate_loaded_data.bat
                        '''
                    }
                }
            }
        }



        /*
        ============================================================
        POSTGRESQL CLEANUP
        WINDOWS
        ============================================================
        */

        stage('PostgreSQL Cleanup') {

            agent {
                label 'windows-node'
            }


            when {

                allOf {

                    expression {
                        params.DATABASE == 'POSTGRESQL'
                    }

                    expression {
                        params.ACTION == 'CLEANUP'
                    }
                }
            }


            steps {

                checkout scm


                script {

                    runPipeline(
                        'postgresql',
                        'cleanup',
                        'windows'
                    ) {

                        withEnv([
                            "CLEANUP_MODE=${params.CLEANUP_MODE}"
                        ]) {

                            bat '''
                                scripts\\batch\\postgresql\\cleanup\\postgresql_cleanup_pipeline.bat
                            '''
                        }
                    }
                }
            }
        }
    }


    post {

        success {

            echo """
            ============================================
            MASTER DATABASE PIPELINE SUCCESSFUL
            DATABASE : ${params.DATABASE}
            ACTION   : ${params.ACTION}
            ============================================
            """
        }


        failure {

            echo """
            ============================================
            MASTER DATABASE PIPELINE FAILED
            DATABASE : ${params.DATABASE}
            ACTION   : ${params.ACTION}
            ============================================
            """
        }


        always {

            echo 'MASTER DATABASE PIPELINE COMPLETED'
        }
    }
}