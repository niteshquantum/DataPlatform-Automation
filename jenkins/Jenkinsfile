                                'mongodb',
                                'setup',
                                'Check Administrator Privileges'
                            ) {

                                checkAdministratorPrivileges(
                                    'mongodb',
                                    'setup',
                                    'Global Mongosh and MongoDB Service'
                                )
                            }
                        }
                    }
                }


                stage('MongoDB Setup - Validate Python Runtime') {

                    steps {

                        script {

                            runTrackedStage(
                                'mongodb',
                                'setup',
                                'Validate Python Runtime'
