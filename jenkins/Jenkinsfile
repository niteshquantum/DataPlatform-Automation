                                'mysql',
                                'setup',
                                'Check Administrator Privileges'
                            ) {

                                checkAdministratorPrivileges(
                                    'mysql',
                                    'setup',
                                    'MySQL Service'
                                )
                            }
                        }
                    }
                }


                stage('MySQL Setup - Validate Python Runtime') {

                    steps {

                        script {

                            runTrackedStage(
                                'mysql',
                                'setup',
                                'Validate Python Runtime'
                            ) {

                                bat 'scripts\\batch\\common\\validate_python_runtime.bat'
                            }
                        }
                    }
                }


                stage('MySQL Setup - Install Python Requirements') {

                    steps {

                        script {

                            runTrackedStage(
                                'mysql',
                                'setup',
                                'Install Python Requirements'
                            ) {

                                bat 'scripts\\batch\\mysql\\setup\\install_python_requirements.bat'
                            }
                        }
                    }
                }


                stage('MySQL Setup - Validate Python Requirements') {

                    steps {

                        script {

                            runTrackedStage(
                                'mysql',
                                'setup',
                                'Validate Python Requirements'
                            ) {

                                bat 'scripts\\batch\\mysql\\setup\\validate_python_requirements.bat'
                            }
                        }
                    }
                }


                stage('MySQL Setup - Validate Java Runtime') {

                    steps {

                        script {

                            runTrackedStage(
                                'mysql',
                                'setup',
                                'Validate Java Runtime'
                            ) {

                                bat 'scripts\\batch\\common\\validate_java_runtime.bat'
                            }
                        }
                    }
                }


                stage('MySQL Setup - Install Tools') {

                    steps {

                        script {

                            runTrackedStage(
                                'mysql',
                                'setup',
                                'Install Tools'
                            ) {

                                bat 'scripts\\batch\\mysql\\setup\\install_tools.bat'
                            }
                        }
                    }
                }


                stage('MySQL Setup - Deploy MySQL') {

                    steps {

                        script {

                            runTrackedStage(
                                'mysql',
                                'setup',
                                'Deploy MySQL'
                            ) {

                                bat 'scripts\\batch\\mysql\\setup\\deploy_mysql.bat'
                            }
                        }
                    }
                }


                stage('MySQL Setup - Configure MySQL Service') {

                    when {

                        expression {

                            return readFile(
                                'admin_status.txt'
                            ).trim() == 'true'
                        }
                    }


                    steps {

                        script {

                            runTrackedStage(
                                'mysql',
                                'setup',
                                'Configure MySQL Service'
                            ) {

                                echo 'Administrator privileges available.'
                                echo 'Configuring MySQL Windows Service...'

                                bat 'scripts\\batch\\mysql\\setup\\configure_mysql_service.bat'
                            }
                        }
                    }
                }


                stage('MySQL Setup - Start MySQL') {

                    when {

                        expression {

                            return readFile(
                                'admin_status.txt'
                            ).trim() != 'true'
                        }
                    }


                    steps {

                        script {

                            runTrackedStage(
                                'mysql',
                                'setup',
                                'Start MySQL'
                            ) {

                                echo 'Administrator privileges unavailable.'
                                echo 'Starting MySQL in project-local mode...'

                                bat 'scripts\\batch\\mysql\\setup\\start_mysql.bat'
                            }
                        }
                    }
                }


                stage('MySQL Setup - Create Database') {

                    steps {

                        script {

                            runTrackedStage(
                                'mysql',
                                'setup',
                                'Create Database'
                            ) {

                                bat 'scripts\\batch\\mysql\\setup\\create_database.bat'
                            }
                        }
                    }
                }


                stage('MySQL Setup - Configure Global MySQL') {

                    when {

                        expression {

                            return readFile(
                                'admin_status.txt'
                            ).trim() == 'true'
                        }
                    }


                    steps {

                        script {

                            runTrackedStage(
                                'mysql',
                                'setup',
                                'Configure Global MySQL'
                            ) {

                                echo 'Administrator privileges available.'
                                echo 'Configuring Global MySQL command...'

                                bat 'scripts\\batch\\mysql\\setup\\configure_global_mysql.bat'
                            }
                        }
                    }
                }


                stage('MySQL Setup - Validate Environment') {

                    steps {

                        script {

                            runTrackedStage(
                                'mysql',
                                'setup',
                                'Validate Environment'
                            ) {

                                bat 'scripts\\batch\\mysql\\setup\\validate_environment.bat'
                            }
                        }
                    }
                }
            }


            post {

                success {

                    script {

                        def adminResult = readFile(
                            'admin_status.txt'
                        ).trim()

                        if (adminResult == 'true') {

                            echo 'MySQL Windows Service configured successfully.'
                            echo 'Global MySQL configuration completed successfully.'

                        } else {

                            echo 'MySQL configured successfully in project-local mode.'
                            echo 'Windows Service and Global MySQL configuration were skipped because Administrator privileges were unavailable.'
                        }
                    }

                    echo 'MYSQL SETUP SUCCESSFUL'
                }


                failure {

                    echo 'MYSQL SETUP FAILED'
                }


                always {

                    script {

                        finalizeLoggingAndReporting(
                            'mysql',
                            'setup',
                            currentBuild.currentResult
                        )
                    }

                    echo 'MYSQL SETUP PIPELINE COMPLETED'
                }
            }
        }



