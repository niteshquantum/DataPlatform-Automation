// ============================================================
// MASTER DATABASE PIPELINE - WINDOWS + UBUNTU
// Databases : MYSQL, MONGODB, POSTGRESQL
// Actions   : SETUP, LOAD, CLEANUP (CLEANUP is Windows only)
// OS        : WINDOWS, UBUNTU (both fully integrated with
//             logger.py stage tracking + report/history generation)
// ============================================================


def initializeLogging(String database, String action, String operatingSystem) {

    if (isUnix()) {

        sh """
            python3 scripts/logging/logger.py init \
            --database "${database}" \
            --action "${action}" \
            --os "${operatingSystem}" \
            --build-number "${env.BUILD_NUMBER}" \
            --job-name "${env.JOB_NAME}" \
            --build-url "${env.BUILD_URL}"
        """

    } else {

        bat """
            python scripts\\logging\\logger.py init ^
            --database "${database}" ^
            --action "${action}" ^
            --os "${operatingSystem}" ^
            --build-number "${env.BUILD_NUMBER}" ^
            --job-name "${env.JOB_NAME}" ^
            --build-url "${env.BUILD_URL}"
        """
    }
}


def runTrackedStage(
    String database,
    String action,
    String stageName,
    Closure stageBody
) {

    if (isUnix()) {

        sh """
            python3 scripts/logging/logger.py stage-start \
            --database "${database}" \
            --action "${action}" \
            --build-number "${env.BUILD_NUMBER}" \
            --stage-name "${stageName}"
        """

    } else {

        bat """
            python scripts\\logging\\logger.py stage-start ^
            --database "${database}" ^
            --action "${action}" ^
            --build-number "${env.BUILD_NUMBER}" ^
            --stage-name "${stageName}"
        """
    }


    try {

        stageBody()

        if (isUnix()) {

            sh """
                python3 scripts/logging/logger.py stage-end \
                --database "${database}" \
                --action "${action}" \
                --build-number "${env.BUILD_NUMBER}" \
                --stage-name "${stageName}" \
                --status SUCCESS
            """

        } else {

            bat """
                python scripts\\logging\\logger.py stage-end ^
                --database "${database}" ^
                --action "${action}" ^
                --build-number "${env.BUILD_NUMBER}" ^
                --stage-name "${stageName}" ^
                --status SUCCESS
            """
        }

    } catch (Exception error) {

        if (isUnix()) {

            sh """
                python3 scripts/logging/logger.py stage-end \
                --database "${database}" \
                --action "${action}" \
                --build-number "${env.BUILD_NUMBER}" \
                --stage-name "${stageName}" \
                --status FAILURE
            """

            sh """
                python3 scripts/logging/logger.py set-error \
                --database "${database}" \
                --action "${action}" \
                --build-number "${env.BUILD_NUMBER}" \
                --failed-stage "${stageName}" \
                --message "Stage execution failed"
            """

        } else {

            bat """
                python scripts\\logging\\logger.py stage-end ^
                --database "${database}" ^
                --action "${action}" ^
                --build-number "${env.BUILD_NUMBER}" ^
                --stage-name "${stageName}" ^
                --status FAILURE
            """

            bat """
                python scripts\\logging\\logger.py set-error ^
                --database "${database}" ^
                --action "${action}" ^
                --build-number "${env.BUILD_NUMBER}" ^
                --failed-stage "${stageName}" ^
                --message "Stage execution failed"
            """
        }

        throw error
    }
}


def checkAdministratorPrivileges(String database, String action, String serviceLabel) {

    def adminStatus = bat(
        script: 'scripts\\batch\\common\\check_admin_privileges.bat',
        returnStatus: true
    )

    if (adminStatus == 0) {

        writeFile(
            file: 'admin_status.txt',
            text: 'true'
        )

        echo 'Administrator privileges available.'
        echo "${serviceLabel} and Global configuration will be enabled."

    } else {

        writeFile(
            file: 'admin_status.txt',
            text: 'false'
        )

        echo 'Administrator privileges not available.'
        echo "${serviceLabel} and Global configuration will be skipped."
        echo "${database.toUpperCase()} will run using project-local mode."
    }

    def adminResult = readFile(
        'admin_status.txt'
    ).trim()

    echo "ADMIN STATUS = ${adminResult}"

    bat """
        python scripts\\logging\\logger.py set-environment ^
        --database "${database}" ^
        --action "${action}" ^
        --build-number "${env.BUILD_NUMBER}" ^
        --administrator-privileges "${adminResult}"
    """
}


def finalizeLoggingAndReporting(
    String database,
    String action,
    String finalStatus
) {

    if (isUnix()) {

        sh """
            python3 scripts/logging/logger.py finalize \
            --database "${database}" \
            --action "${action}" \
            --build-number "${env.BUILD_NUMBER}" \
            --status "${finalStatus}"
        """

        sh """
            python3 scripts/reporting/generate_report.py \
            --database "${database}" \
            --action "${action}" \
            --build-number "${env.BUILD_NUMBER}"
        """

        sh """
            python3 scripts/reporting/generate_history.py \
            --database "${database}" \
            --action "${action}" \
            --build-number "${env.BUILD_NUMBER}"
        """

    } else {

        bat """
            python scripts\\logging\\logger.py finalize ^
            --database "${database}" ^
            --action "${action}" ^
            --build-number "${env.BUILD_NUMBER}" ^
            --status "${finalStatus}"
        """

        bat """
            python scripts\\reporting\\generate_report.py ^
            --database "${database}" ^
            --action "${action}" ^
            --build-number "${env.BUILD_NUMBER}"
        """

        bat """
            python scripts\\reporting\\generate_history.py ^
            --database "${database}" ^
            --action "${action}" ^
            --build-number "${env.BUILD_NUMBER}"
        """
    }

    archiveArtifacts(
        artifacts:
            "logs/${database.toLowerCase()}/${action.toLowerCase()}/build_${env.BUILD_NUMBER}/**, " +
            "reports/${database.toLowerCase()}/${action.toLowerCase()}/build_${env.BUILD_NUMBER}/**, " +
            "reports/history/**",
        fingerprint: true,
        allowEmptyArchive: true
    )
}


pipeline {

    agent none


    options {

        disableConcurrentBuilds()
    }


    parameters {

        choice(
            name: 'DATABASE',
            choices: [
                'MYSQL',
                'MONGODB',
                'POSTGRESQL'
            ],
            description: 'Select Database'
        )


        choice(
            name: 'ACTION',
            choices: [
                'SETUP',
                'LOAD',
                'CLEANUP'
            ],
            description: 'Select Action'
        )


        choice(
            name: 'CLEANUP_MODE',
            choices: [
                'PRESERVE_DATA',
                'DELETE_DATA'
            ],
            description: 'Select cleanup mode (only used when ACTION = CLEANUP)'
        )


        choice(
            name: 'OS',
            choices: [
                'WINDOWS',
                'UBUNTU'
            ],
            description: 'Select operating system (only used when ACTION = SETUP or LOAD; CLEANUP is Windows only)'
        )
    }


    stages {


        /*
        ============================================================
        MYSQL SETUP (WINDOWS)
        ============================================================
        */


        stage('MySQL Setup') {

            agent {
                label 'windows-node'
            }


            when {

                allOf {

                    expression {
                        params.DATABASE == 'MYSQL'
                    }

                    expression {
                        params.ACTION == 'SETUP'
                    }

                    expression {
                        params.OS == 'WINDOWS'
