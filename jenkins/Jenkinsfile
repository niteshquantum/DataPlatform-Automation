                allOf {
                    expression { params.DATABASE == 'POSTGRESQL' }
                    expression { params.ACTION == 'LOAD' }
                }
            }

            stages {

                stage('PostgreSQL Load - Checkout SCM') {
                    steps {
                        checkout scm
                    }
                }

                stage('PostgreSQL Load - Initialize Logging') {
                    steps {
