                stage('MySQL Setup - Start MySQL') {
                    steps {
                        script {
                            runTrackedStage('mysql', 'setup', 'Start MySQL') {
                                sh './scripts/bash/mysql/setup/start_mysql.sh'
                            }
                        }
                    }
                }

                stage('MySQL Setup - Create Database') {
                    steps {
                        script {
                            runTrackedStage('mysql', 'setup', 'Create Database') {
                                sh './scripts/bash/mysql/setup/create_database.sh'
                            }
                        }
                    }
                }

                stage('MySQL Setup - Configure Global MySQL') {
                    steps {
                        script {
                            runTrackedStage('mysql', 'setup', 'Configure Global MySQL') {
                                sh './scripts/bash/mysql/setup/configure_global_mysql.sh'
