                            runTrackedStage(
                                'mongodb',
                                'cleanup',
                                'Execute Cleanup'
                            ) {

                                withEnv([
                                    "CLEANUP_MODE=${params.CLEANUP_MODE}"
                                ]) {

                                    bat 'scripts\\batch\\mongodb\\cleanup\\mongodb_cleanup_pipeline.bat'
                                }
                            }
                        }
                    }
                }
