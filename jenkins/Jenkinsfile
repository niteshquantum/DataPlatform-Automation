                checkout scm


                script {

                    executePipeline(
                        'mongodb',
                        'setup',
                        'windows'
                    ) {

                        bat 'scripts\\batch\\mongodb\\mongodb_setup_pipeline.bat'
                    }
                }
            }
        }


        /*
        ============================================================
        MONGODB LOAD
        WINDOWS
        ============================================================
        */

        stage('MongoDB Load') {

            agent {
                label 'windows-node'
            }


            when {

                allOf {
					expression { currentBuild.number > 1 }
                    expression {
                        params.DATABASE == 'MONGODB'
                    }

                    expression {
                        params.ACTION == 'LOAD'
                    }
                }
            }


            steps {

                checkout scm


                script {

                    executePipeline(
                        'mongodb',
                        'load',
                        'windows'
                    ) {

                        bat 'scripts\\batch\\mongodb\\mongodb_load_pipeline.bat'
                    }
                }
            }
        }


        /*
        ============================================================
        MONGODB CLEANUP
        WINDOWS
        ============================================================
        */

        stage('MongoDB Cleanup') {

            agent {
                label 'windows-node'
            }


            when {

                allOf {
					expression { currentBuild.number > 1 }
                    expression {
                        params.DATABASE == 'MONGODB'
                    }

                    expression {
                        params.ACTION == 'CLEANUP'
                    }
                }
            }


            steps {

                checkout scm


                script {

                    executePipeline(
                        'mongodb',
                        'cleanup',
                        'windows'
                    ) {

                        withEnv([
                            "CLEANUP_MODE=${params.CLEANUP_MODE}"
                        ]) {

                            bat 'scripts\\batch\\mongodb\\cleanup\\mongodb_cleanup_pipeline.bat'
                        }
                    }
                }
            }
        }


        /*
        ============================================================
        POSTGRESQL SETUP
        WINDOWS
        ============================================================
        */

        stage('PostgreSQL Setup') {

            agent {
                label 'windows-node'
            }


            when {

                allOf {
					expression { currentBuild.number > 1 }
                    expression {
                        params.DATABASE == 'POSTGRESQL'
                    }

                    expression {
                        params.ACTION == 'SETUP'
                    }
                }
            }


            steps {

                checkout scm


                script {

                    executePipeline(
                        'postgresql',
                        'setup',
                        'windows'
                    ) {

                        bat 'scripts\\batch\\postgresql\\postgresql_setup_pipeline.bat'
                    }
                }
            }
        }


        /*
        ============================================================
        POSTGRESQL LOAD
        WINDOWS
        ============================================================
        */

        stage('PostgreSQL Load') {

            agent {
                label 'windows-node'
            }


            when {

                allOf {
					expression { currentBuild.number > 1 }
                    expression {
                        params.DATABASE == 'POSTGRESQL'
                    }

                    expression {
                        params.ACTION == 'LOAD'
                    }
                }
            }


            steps {

                checkout scm


                script {

                    executePipeline(
                        'postgresql',
                        'load',
                        'windows'
                    ) {

                        bat 'scripts\\batch\\postgresql\\postgresql_load_pipeline.bat'
                    }
                }
            }
        }


        /*
        ============================================================
        POSTGRESQL CLEANUP
        WINDOWS
        ============================================================
        */

        stage('PostgreSQL Cleanup') {

            agent {
                label 'windows-node'
            }


            when {

                allOf {
					expression { currentBuild.number > 1 }
                    expression {
                        params.DATABASE == 'POSTGRESQL'
                    }

                    expression {
                        params.ACTION == 'CLEANUP'
                    }
                }
            }


            steps {

                checkout scm


                script {

                    executePipeline(
                        'postgresql',
                        'cleanup',
                        'windows'
                    ) {

                        withEnv([
                            "CLEANUP_MODE=${params.CLEANUP_MODE}"
                        ]) {

                            bat 'scripts\\batch\\postgresql\\cleanup\\postgresql_cleanup_pipeline.bat'
                        }
                    }
                }
            }
        }
    }


    post {

        success {

            echo """
            ============================================
            MASTER DATABASE PIPELINE SUCCESSFUL
            DATABASE : ${params.DATABASE}
            ACTION   : ${params.ACTION}
            ============================================
            """
        }


        failure {

            echo """
            ============================================
            MASTER DATABASE PIPELINE FAILED
            DATABASE : ${params.DATABASE}
            ACTION   : ${params.ACTION}
            ============================================
            """
        }


        always {

            echo 'MASTER DATABASE PIPELINE COMPLETED'
        }
    }
}