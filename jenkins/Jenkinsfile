/*
============================================================
COMMON LOGGING AND REPORTING FUNCTION
============================================================
*/

def executePipeline(
    String database,
    String action,
    String operatingSystem,
    Closure executionBody
) {

    def finalStatus = 'SUCCESS'
    def originalError = null
    def loggingInitialized = false

    try {

        /*
        ============================================================
        RBAC AUTHENTICATION
        ============================================================
        */

        def permission = "${database}.${action}".toLowerCase()

        echo "RBAC Permission : ${permission}"

        def authResult

        if (isUnix()) {

            authResult = sh(
                script: """
                    python3 rbac/auth_cli.py \
                        --username "${params.USERNAME}" \
                        --password "${params.PASSWORD}"
                """,
                returnStdout: true
            ).trim()

        } else {

            authResult = bat(
                script: """
                    @echo off
                    python rbac\\auth_cli.py ^
                        --username "${params.USERNAME}" ^
                        --password "${params.PASSWORD}"
                """,
                returnStdout: true
            ).trim()
        }

        def role = authResult.readLines().last().trim()

        echo "Logged in Role : ${role}"

        if (role.equalsIgnoreCase("Viewer")) {

            echo "=========================================="
            echo "Viewer Role Detected"
            echo "Publishing Executive Report"
            echo "=========================================="

		if (action == "load") {
		
		    publishHTML([
		        allowMissing: true,
		        alwaysLinkToLastBuild: true,
		        keepAll: true,
		        reportDir: "reports/migration/${database}",
		        reportFiles: "executive_report.html",
		        reportName: "${database.toUpperCase()} Executive Report"
		    ])
		
		}

            return
        }

        /*
        ============================================================
        RBAC AUTHORIZATION
        ============================================================
        */

        if (isUnix()) {

            sh """
                python3 rbac/cli.py \
                    --username "${params.USERNAME}" \
                    --password "${params.PASSWORD}" \
                    --permission "${permission}"
            """

        } else {

            bat """
                @echo off
                python rbac\\cli.py ^
                    --username "${params.USERNAME}" ^
                    --password "${params.PASSWORD}" ^
                    --permission "${permission}"
            """
        }

        /*
        ============================================================
        INITIALIZE LOGGING
        ============================================================
        
        */

        if (isUnix()) {

            sh """
                python3 scripts/logging/logger.py init \
                    --database "${database}" \
                    --action "${action}" \
                    --os "${operatingSystem}" \
                    --build-number "${env.BUILD_NUMBER}" \
                    --job-name "${env.JOB_NAME}" \
                    --build-url "${env.BUILD_URL}"
            """

        } else {

            bat """
                python scripts\\logging\\logger.py init ^
                    --database "${database}" ^
                    --action "${action}" ^
                    --os "${operatingSystem}" ^
                    --build-number "${env.BUILD_NUMBER}" ^
                    --job-name "${env.JOB_NAME}" ^
                    --build-url "${env.BUILD_URL}"
            """
        }

        loggingInitialized = true

        /*
        ============================================================
        EXECUTE ORIGINAL PIPELINE FLOW
        ============================================================
        */

        executionBody()

    } catch (Exception error) {

        finalStatus = 'FAILURE'
        originalError = error

    } finally {

        /*
        ============================================================
        FINALIZE LOGGING
        ============================================================
        */

        if (loggingInitialized) {

            try {

                if (isUnix()) {

                    sh """
                        python3 scripts/logging/logger.py finalize \
                            --database "${database}" \
                            --action "${action}" \
                            --build-number "${env.BUILD_NUMBER}" \
                            --status "${finalStatus}"
                    """

                } else {

                    bat """
                        python scripts\\logging\\logger.py finalize ^
                            --database "${database}" ^
                            --action "${action}" ^
                            --build-number "${env.BUILD_NUMBER}" ^
                            --status "${finalStatus}"
                    """
                }

            } catch (Exception finalizeError) {

                echo "WARNING: Logging finalization failed: ${finalizeError}"
            }


            /*
            ============================================================
            GENERATE REPORT
            ============================================================
            */

            try {

                if (isUnix()) {

                    sh """
                        python3 scripts/reporting/generate_report.py \
                            --database "${database}" \
                            --action "${action}" \
                            --build-number "${env.BUILD_NUMBER}"
                    """

                    sh """
                        python3 scripts/reporting/generate_history.py \
                            --database "${database}" \
                            --action "${action}" \
                            --build-number "${env.BUILD_NUMBER}"
                    """

                } else {

                    bat """
                        python scripts\\reporting\\generate_report.py ^
                            --database "${database}" ^
                            --action "${action}" ^
                            --build-number "${env.BUILD_NUMBER}"
                    """

                    bat """
                        python scripts\\reporting\\generate_history.py ^
                            --database "${database}" ^
                            --action "${action}" ^
                            --build-number "${env.BUILD_NUMBER}"
                    """
                }

            } catch (Exception reportError) {

                echo "WARNING: Report generation failed: ${reportError}"
            }


            /*
            ============================================================
            ARCHIVE LOGS AND REPORTS
            ============================================================
            */

            try {

                archiveArtifacts(
                    artifacts:
                        "logs/${database}/${action}/build_${env.BUILD_NUMBER}/**," +
                        "reports/${database}/${action}/build_${env.BUILD_NUMBER}/**," +
                        "reports/history/**," +
                        "reports/migration/${database}/**," +
                        "outputs/assessments/${database}/**," +
                        "outputs/assessments/assessment_report.json," +
                        "metadata/profiling/${database}/**," +
                        "metadata/reconciliation/${database}/**," +
                        "metadata/discovery/${database}/**," +
                        "metadata/assessment/${database}/**," +
                        "metadata/recommendation/${database}/**," +
                        "metadata/governance/${database}/**",
                    fingerprint: true,
                    allowEmptyArchive: true
                )
                publishHTML([
                    allowMissing: true,
                    alwaysLinkToLastBuild: true,
                    keepAll: true,
                    reportDir: "reports/migration/${database}",
                    reportFiles: "executive_report.html",
                    reportName: "${database.toUpperCase()} Executive Report"
                ])

            } catch (Exception archiveError) {

                echo "WARNING: Artifact archiving failed: ${archiveError}"
            }
        }
    }


    /*
    ============================================================
    RESTORE ORIGINAL PIPELINE FAILURE
    ============================================================
    */

    if (originalError != null) {
        throw originalError
    }
}


/*
============================================================
MASTER DATABASE PIPELINE
============================================================
*/

pipeline {

    agent none


    options {

        disableConcurrentBuilds()
    }


    parameters {

        choice(
            name: 'DATABASE',
            choices: [
                'MYSQL',
                'MSSQL',
                'MONGODB',
                'POSTGRESQL'
            ],
            description: 'Select Database'
        )


        choice(
            name: 'ACTION',
            choices: [
                'SETUP',
                'LOAD',
                'CLEANUP'
            ],
            description: 'Select Action'
        )


        choice(
            name: 'CLEANUP_MODE',
            choices: [
                'PRESERVE_DATA',
                'DELETE_DATA'
            ],
            description: 'Select CLEANUP mode'
        )

        string(
            name: 'USERNAME',
            defaultValue: '',
            description: 'RBAC Username'
        )

        password(
            name: 'PASSWORD',
            defaultValue: '',
            description: 'RBAC Password'
)
    }


    stages {

        /*
        ============================================================
        VALIDATE SELECTION
        ============================================================
        */

stage('Validate Selection') {

    agent any

    steps {

        script {

if (currentBuild.number == 1) {

    currentBuild.description = "Parameters Registered"

if (currentBuild.number == 1) {
    echo "First build detected. Parameters will be available after this build."
}
}

    echo "============================================"
    echo "MASTER DATABASE PIPELINE"
    echo "============================================"
    echo "DATABASE     : ${params.DATABASE}"
    echo "ACTION       : ${params.ACTION}"

    if (params.ACTION == 'CLEANUP') {
        echo "CLEANUP MODE : ${params.CLEANUP_MODE}"
    }

    echo "============================================"

                }
            }
        }


        /*
        ============================================================
        MYSQL SETUP
        UBUNTU
        ============================================================
        */

        stage('MySQL Setup') {

            agent {
                label 'ubuntu-node'
            }


		when {
		    allOf {
		        expression { currentBuild.number > 1 }
		        expression { params.DATABASE == 'MYSQL' }
		        expression { params.ACTION == 'SETUP' }
		    }
		}


            steps {

                checkout scm


                script {

                    executePipeline(
                        'mysql',
                        'setup',
                        'ubuntu'
                    ) {

                        sh '''
                            find scripts/bash -type f -name "*.sh" -exec chmod +x {} \\;
                        '''

                        sh 'bash ./scripts/bash/common/validate_python_runtime.sh'

                        sh 'bash ./scripts/bash/mysql/setup/install_python_requirements.sh'

                         sh 'bash ./scripts/bash/mysql/setup/validate_python_requirements.sh'

                        sh 'bash ./scripts/bash/common/validate_java_runtime.sh'

                        sh 'bash ./scripts/bash/mysql/setup/install_tools.sh'

                        sh 'bash ./scripts/bash/mysql/setup/install_mysql.sh'

                        sh 'bash ./scripts/bash/mysql/setup/deploy_mysql.sh'

                        sh 'bash ./scripts/bash/mysql/setup/start_mysql.sh'

                        sh 'bash ./scripts/bash/mysql/setup/create_database.sh'
						
						sh 'bash ./scripts/bash/mysql/setup/run_liquibase.sh'

                        sh 'bash ./scripts/bash/mysql/setup/configure_global_mysql.sh'

                        sh 'bash ./scripts/bash/mysql/setup/validate_environment.sh'
                    }
                }
            }
        }


        /*
        ============================================================
        MYSQL LOAD
        UBUNTU
        ============================================================
        */

        stage('MySQL Load') {

            agent {
                label 'ubuntu-node'
            }


            when {

                allOf {
					expression { currentBuild.number > 1 }
                    expression {
                        params.DATABASE == 'MYSQL'
                    }

                    expression {
                        params.ACTION == 'LOAD'
                    }
                }
            }


            steps {

                checkout scm


                script {

                    executePipeline(
                        'mysql',
                        'load',
                        'ubuntu'
                    ) {

                        sh '''
                            find scripts/bash -type f -name "*.sh" -exec chmod +x {} \\;
                        '''

                        sh 'bash ./scripts/bash/common/validate_python_runtime.sh'

                        sh 'bash ./scripts/bash/mysql/setup/validate_python_requirements.sh'

                        sh 'bash ./scripts/bash/mysql/setup/start_mysql.sh'

                        sh 'bash ./scripts/bash/mysql/setup/validate_mysql.sh'

                        sh 'bash ./scripts/bash/common/download_dataset.sh'

                        sh 'bash ./scripts/bash/common/migration/run_data_profiling.sh mysql'

                        sh 'bash ./scripts/bash/mysql/load/load_data.sh'

                        sh 'bash ./scripts/bash/mysql/load/validate_loaded_data.sh'

                        sh './scripts/bash/mysql/objects/deploy_objects.sh'

                        sh './scripts/bash/mysql/assessment/run_assessment.sh all'

                        sh './scripts/bash/common/generate_assessment_report.sh'
                         
                        sh './scripts/bash/common/run_reconciliation.sh mysql'

                        sh 'python3 scripts/discovery/discovery_engine.py --database mysql'

                        sh 'python3 scripts/discovery/growth_analyzer.py --database mysql'

                        sh 'python3 scripts/discovery/discovery_engine.py --database mysql'

                        sh 'python3 scripts/discovery/growth_analyzer.py --database mysql'

                        sh 'python3 scripts/discovery/requirement_analyzer.py --database mysql'

                        sh './scripts/bash/common/migration/run_assessment.sh mysql'

                        sh './scripts/bash/common/migration/run_recommendation.sh mysql'

                        sh './scripts/bash/common/migration/run_action_plan.sh mysql'

                        sh './scripts/bash/common/migration/generate_technical_report.sh mysql'

                        sh './scripts/bash/common/migration/generate_executive_report.sh mysql'
                    }
                }
            }
        }


        /*
        ============================================================
        MYSQL CLEANUP
        UBUNTU
        ============================================================
        */

        stage('MySQL Cleanup') {

            agent {
                label 'ubuntu-node'
            }


            when {
				
                allOf {
					expression { currentBuild.number > 1 }
                    expression {
                        params.DATABASE == 'MYSQL'
                    }

                    expression {
                        params.ACTION == 'CLEANUP'
                    }
                }
            }


            steps {

                checkout scm


                script {

                    executePipeline(
                        'mysql',
                        'cleanup',
                        'ubuntu'
                    ) {

                        withEnv([
                            "CLEANUP_MODE=${params.CLEANUP_MODE}"
                        ]) {

                            sh '''
                                find scripts/bash -type f -name "*.sh" -exec chmod +x {} \\;
                            '''

                            sh 'bash scripts/bash/mysql/cleanup/mysql_cleanup_pipeline.sh'
                        }
                    }
                }
            }
        }


        /*
        ============================================================
        MSSQL SETUP
        UBUNTU
        ============================================================
        */

        stage('MSSQL Setup') {

            agent {
                label 'ubuntu-node'
            }


            when {

                allOf {
					expression { currentBuild.number > 1 }
                    expression {
                        params.DATABASE == 'MSSQL'
                    }

                    expression {
                        params.ACTION == 'SETUP'
                    }
                }
            }


            steps {

                checkout scm


                script {

                    executePipeline(
                        'mssql',
                        'setup',
                        'ubuntu'
                    ) {

                        sh '''
                            find scripts/bash -type f -name "*.sh" -exec chmod +x {} \\;
                        '''

                        sh 'bash ./scripts/bash/common/validate_python_runtime.sh'

                        sh 'bash ./scripts/bash/common/validate_java_runtime.sh'

                        sh 'bash ./scripts/bash/mssql/setup/install_tools.sh'

                        sh 'bash ./scripts/bash/mssql/setup/install_mssql_driver.sh'

                        sh 'bash ./scripts/bash/mssql/setup/install_mssql.sh'

                        

                        sh 'bash ./scripts/bash/mssql/setup/start_mssql.sh'

                        sh 'bash ./scripts/bash/mssql/setup/create_database.sh'

                        sh 'bash ./scripts/bash/mssql/setup/run_liquibase.sh'

						sh 'bash ./scripts/bash/mssql/setup/configure_global_mssql.sh'
						
                        sh 'bash ./scripts/bash/mssql/setup/validate_environment.sh'
                    }
                }
            }
        }


        /*
        ============================================================
        MSSQL LOAD
        UBUNTU
        ============================================================
        */

        stage('MSSQL Load') {

            agent {
                label 'ubuntu-node'
            }


            when {

                allOf {
					expression { currentBuild.number > 1 }
                    expression {
                        params.DATABASE == 'MSSQL'
                    }

                    expression {
                        params.ACTION == 'LOAD'
                    }
                }
            }


            steps {

                checkout scm


                script {

                    executePipeline(
                        'mssql',
                        'load',
                        'ubuntu'
                    ) {

                        sh '''
                            find scripts/bash -type f -name "*.sh" -exec chmod +x {} \\;
                        '''

                        sh 'bash ./scripts/bash/common/validate_python_runtime.sh'

                        sh 'bash ./scripts/bash/mssql/setup/install_python_requirements.sh'

                        sh 'bash ./scripts/bash/mssql/setup/validate_python_requirements.sh'

                        sh 'bash ./scripts/bash/mssql/setup/install_tools.sh'

                        sh 'bash ./scripts/bash/mssql/setup/validate_tools.sh'

                        sh 'bash ./scripts/bash/mssql/setup/validate_mssql.sh'

                        sh 'bash ./scripts/bash/common/download_dataset.sh'

                        sh 'bash ./scripts/bash/common/migration/run_data_profiling.sh mssql'

                        sh 'bash ./scripts/bash/mssql/load/load_data.sh'

                        sh 'bash ./scripts/bash/mssql/load/validate_loaded_data.sh'

                        sh './scripts/bash/mssql/objects/deploy_objects.sh'
					
						sh './scripts/bash/mssql/assessment/run_assessment.sh all'

                        sh './scripts/bash/common/generate_assessment_report.sh'

                        sh './scripts/bash/common/migration/run_reconciliation.sh mssql'

                        sh 'python3 scripts/discovery/discovery_engine.py --database mssql'

                        sh 'python3 scripts/discovery/growth_analyzer.py --database mssql'

                        sh 'python3 scripts/discovery/requirement_analyzer.py --database mssql'

                        sh './scripts/bash/common/migration/run_assessment.sh mssql'

                        sh './scripts/bash/common/migration/run_recommendation.sh mssql'

                        sh './scripts/bash/common/migration/run_action_plan.sh mssql'

                        sh './scripts/bash/common/migration/generate_technical_report.sh mssql'

                        sh './scripts/bash/common/migration/generate_executive_report.sh mssql'
                    }
                }
            }
        }


        /*
        ============================================================
        MSSQL CLEANUP
        UBUNTU
        ============================================================
        */

        stage('MSSQL Cleanup') {

            agent {
                label 'ubuntu-node'
            }


            when {

                allOf {
					expression { currentBuild.number > 1 }
                    expression {
                        params.DATABASE == 'MSSQL'
                    }

                    expression {
                        params.ACTION == 'CLEANUP'
                    }
                }
            }


            steps {

                checkout scm


                script {

                    executePipeline(
                        'mssql',
                        'cleanup',
                        'ubuntu'
                    ) {

                        withEnv([
                            "CLEANUP_MODE=${params.CLEANUP_MODE}"
                        ]) {

                            sh '''
                                find scripts/bash -type f -name "*.sh" -exec chmod +x {} \\;
                            '''

                            sh 'bash scripts/bash/mssql/cleanup/mssql_cleanup_pipeline.sh'
                        }
                    }
                }
            }
        }


        /*
        ============================================================
        MONGODB SETUP
        WINDOWS
        ============================================================
        */

        stage('MongoDB Setup') {

            agent {
                label 'windows-node'
            }


            when {

                allOf {
					expression { currentBuild.number > 1 }
                    expression {
                        params.DATABASE == 'MONGODB'
                    }

                    expression {
                        params.ACTION == 'SETUP'
                    }
                }
            }


