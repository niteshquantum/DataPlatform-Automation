def initializeLogging(String database, String action, String operatingSystem) {

    if (isUnix()) {

        sh """
            python3 scripts/logging/logger.py init \
            --database "${database}" \
            --action "${action}" \
            --os "${operatingSystem}" \
            --build-number "${env.BUILD_NUMBER}" \
            --job-name "${env.JOB_NAME}" \
            --build-url "${env.BUILD_URL}"
        """

    } else {

        bat """
            python scripts\\logging\\logger.py init ^
            --database "${database}" ^
            --action "${action}" ^
            --os "${operatingSystem}" ^
            --build-number "${env.BUILD_NUMBER}" ^
            --job-name "${env.JOB_NAME}" ^
            --build-url "${env.BUILD_URL}"
        """
    }
}


def runTrackedStage(
    String database,
    String action,
    String stageName,
    Closure stageBody
) {

    if (isUnix()) {

        sh """
            python3 scripts/logging/logger.py stage-start \
            --database "${database}" \
            --action "${action}" \
            --build-number "${env.BUILD_NUMBER}" \
            --stage-name "${stageName}"
        """

    } else {

        bat """
            python scripts\\logging\\logger.py stage-start ^
            --database "${database}" ^
            --action "${action}" ^
            --build-number "${env.BUILD_NUMBER}" ^
            --stage-name "${stageName}"
        """
    }


    try {

        stageBody()

        if (isUnix()) {

            sh """
                python3 scripts/logging/logger.py stage-end \
                --database "${database}" \
                --action "${action}" \
                --build-number "${env.BUILD_NUMBER}" \
                --stage-name "${stageName}" \
                --status SUCCESS
            """

        } else {

            bat """
                python scripts\\logging\\logger.py stage-end ^
                --database "${database}" ^
                --action "${action}" ^
                --build-number "${env.BUILD_NUMBER}" ^
                --stage-name "${stageName}" ^
                --status SUCCESS
            """
        }

    } catch (Exception error) {

        if (isUnix()) {

            sh """
                python3 scripts/logging/logger.py stage-end \
                --database "${database}" \
                --action "${action}" \
                --build-number "${env.BUILD_NUMBER}" \
                --stage-name "${stageName}" \
                --status FAILURE
            """

            sh """
                python3 scripts/logging/logger.py set-error \
                --database "${database}" \
                --action "${action}" \
                --build-number "${env.BUILD_NUMBER}" \
                --failed-stage "${stageName}" \
                --message "Stage execution failed"
            """

        } else {

            bat """
                python scripts\\logging\\logger.py stage-end ^
                --database "${database}" ^
                --action "${action}" ^
                --build-number "${env.BUILD_NUMBER}" ^
                --stage-name "${stageName}" ^
                --status FAILURE
            """

            bat """
                python scripts\\logging\\logger.py set-error ^
                --database "${database}" ^
                --action "${action}" ^
                --build-number "${env.BUILD_NUMBER}" ^
                --failed-stage "${stageName}" ^
                --message "Stage execution failed"
            """
        }

        throw error
    }
}


def finalizeLoggingAndReporting(
    String database,
    String action,
    String finalStatus
) {

    if (isUnix()) {

        sh """
            python3 scripts/logging/logger.py finalize \
            --database "${database}" \
            --action "${action}" \
            --build-number "${env.BUILD_NUMBER}" \
            --status "${finalStatus}"
        """

        sh """
            python3 scripts/reporting/generate_report.py \
            --database "${database}" \
            --action "${action}" \
            --build-number "${env.BUILD_NUMBER}"
        """

    } else {

        bat """
            python scripts\\logging\\logger.py finalize ^
            --database "${database}" ^
            --action "${action}" ^
            --build-number "${env.BUILD_NUMBER}" ^
            --status "${finalStatus}"
        """

        bat """
            python scripts\\reporting\\generate_report.py ^
            --database "${database}" ^
            --action "${action}" ^
            --build-number "${env.BUILD_NUMBER}"
        """
    }


    archiveArtifacts(
        artifacts:
            "logs/${database.toLowerCase()}/${action.toLowerCase()}/build_${env.BUILD_NUMBER}/**, " +
            "reports/${database.toLowerCase()}/${action.toLowerCase()}/build_${env.BUILD_NUMBER}/**",
        fingerprint: true,
        allowEmptyArchive: true
    )
}


