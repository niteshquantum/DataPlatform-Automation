        echo "CLEANUP MODE : ${params.CLEANUP_MODE}"
    }

    echo "============================================"

                }
            }
        }


        /*
        ============================================================
        MYSQL SETUP
        UBUNTU
        ============================================================
        */

        stage('MySQL Setup') {

