                        }
                    }
                }

                stage('MySQL Setup - Set Permissions') {
                    steps {
                        script {
                            runTrackedStage('mysql', 'setup', 'Set Permissions') {
                                sh '''
                                    find scripts/bash -type f -name "*.sh" -exec chmod +x {} \\;
                                '''
                            }
                        }
                    }
                }

