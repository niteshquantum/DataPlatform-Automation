/*
============================================================
COMMON LOGGING AND REPORTING FUNCTION
============================================================
*/

def executePipeline(
    String database,
    String action,
    String operatingSystem,
    Closure executionBody
) {

    def finalStatus = 'SUCCESS'
    def originalError = null
    def loggingInitialized = false

    try {

        /*
        ============================================================
        INITIALIZE LOGGING
        ============================================================
        */

        if (isUnix()) {

            sh """
                python3 scripts/logging/logger.py init \
                    --database "${database}" \
                    --action "${action}" \
                    --os "${operatingSystem}" \
                    --build-number "${env.BUILD_NUMBER}" \
                    --job-name "${env.JOB_NAME}" \
                    --build-url "${env.BUILD_URL}"
            """

        } else {

            bat """
                python scripts\\logging\\logger.py init ^
                    --database "${database}" ^
                    --action "${action}" ^
                    --os "${operatingSystem}" ^
                    --build-number "${env.BUILD_NUMBER}" ^
                    --job-name "${env.JOB_NAME}" ^
                    --build-url "${env.BUILD_URL}"
            """
        }

        loggingInitialized = true

        /*
        ============================================================
        EXECUTE ORIGINAL PIPELINE FLOW
        ============================================================
        */

        executionBody()

    } catch (Exception error) {

        finalStatus = 'FAILURE'
        originalError = error

    } finally {

        /*
        ============================================================
        FINALIZE LOGGING
        ============================================================
        */

        if (loggingInitialized) {

            try {

                if (isUnix()) {

                    sh """
                        python3 scripts/logging/logger.py finalize \
                            --database "${database}" \
                            --action "${action}" \
                            --build-number "${env.BUILD_NUMBER}" \
                            --status "${finalStatus}"
                    """

                } else {

                    bat """
                        python scripts\\logging\\logger.py finalize ^
                            --database "${database}" ^
                            --action "${action}" ^
                            --build-number "${env.BUILD_NUMBER}" ^
                            --status "${finalStatus}"
                    """
                }

            } catch (Exception finalizeError) {

                echo "WARNING: Logging finalization failed: ${finalizeError}"
            }


            /*
            ============================================================
            GENERATE REPORT
            ============================================================
            */

            try {

                if (isUnix()) {

                    sh """
                        python3 scripts/reporting/generate_report.py \
                            --database "${database}" \
                            --action "${action}" \
                            --build-number "${env.BUILD_NUMBER}"
                    """

                    sh """
                        python3 scripts/reporting/generate_history.py \
                            --database "${database}" \
                            --action "${action}" \
                            --build-number "${env.BUILD_NUMBER}"
                    """

                } else {

                    bat """
                        python scripts\\reporting\\generate_report.py ^
                            --database "${database}" ^
                            --action "${action}" ^
                            --build-number "${env.BUILD_NUMBER}"
                    """

                    bat """
                        python scripts\\reporting\\generate_history.py ^
                            --database "${database}" ^
                            --action "${action}" ^
                            --build-number "${env.BUILD_NUMBER}"
                    """
                }

            } catch (Exception reportError) {

                echo "WARNING: Report generation failed: ${reportError}"
            }


            /*
            ============================================================
            ARCHIVE LOGS AND REPORTS
            ============================================================
            */

            try {

                archiveArtifacts(
                    artifacts:
                        "logs/${database}/${action}/build_${env.BUILD_NUMBER}/**," +
                        "reports/${database}/${action}/build_${env.BUILD_NUMBER}/**," +
                        "reports/history/**," +
                        "reports/migration/${database}/**," +
                        "outputs/assessments/${database}/**," +
                        "outputs/assessments/assessment_report.json," +
                        "metadata/profiling/${database}/**," +
                        "metadata/reconciliation/${database}/**," +
                        "metadata/discovery/${database}/**," +
                        "metadata/assessment/${database}/**," +
                        "metadata/recommendation/${database}/**," +
                        "metadata/governance/${database}/**",
                    fingerprint: true,
                    allowEmptyArchive: true
                )

            } catch (Exception archiveError) {

                echo "WARNING: Artifact archiving failed: ${archiveError}"
            }
        }
    }


    /*
    ============================================================
    RESTORE ORIGINAL PIPELINE FAILURE
    ============================================================
    */

    if (originalError != null) {
        throw originalError
    }
}


/*
============================================================
MASTER DATABASE PIPELINE
============================================================
*/

pipeline {

    agent none


    options {

        disableConcurrentBuilds()
    }


    parameters {

        choice(
            name: 'DATABASE',
            choices: [
                'MYSQL',
                'MSSQL',
                'MONGODB',
                'POSTGRESQL'
            ],
            description: 'Select Database'
        )


        choice(
            name: 'ACTION',
            choices: [
                'SETUP',
                'LOAD',
                'CLEANUP'
            ],
            description: 'Select Action'
        )


        choice(
            name: 'CLEANUP_MODE',
            choices: [
                'PRESERVE_DATA',
