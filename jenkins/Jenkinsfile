                    }

                    echo 'UBUNTU MYSQL LOAD PIPELINE COMPLETED'
                }
            }
        }



        /*
        ============================================================
        MYSQL CLEANUP (WINDOWS)
        ============================================================
        */


        stage('MySQL Cleanup') {

            agent {
                label 'windows-node'
            }


            when {

                allOf {

                    expression {
                        params.DATABASE == 'MYSQL'
                    }

                    expression {
                        params.ACTION == 'CLEANUP'
                    }
                }
            }


            environment {
                PIPELINE_TYPE = "MYSQL_WINDOWS_CLEANUP"
            }


            stages {


                stage('MySQL Cleanup - Checkout SCM') {

                    steps {

                        checkout scm
                    }
                }


                stage('MySQL Cleanup - Initialize Logging') {

                    steps {

                        script {

                            initializeLogging(
                                'mysql',
                                'cleanup',
                                'windows'
                            )
                        }
                    }
                }


                stage('MySQL Cleanup - Cleanup Information') {

                    steps {

                        script {

                            runTrackedStage(
                                'mysql',
                                'cleanup',
                                'Cleanup Information'
                            ) {

                                echo "====================================="
                                echo "MYSQL WINDOWS CLEANUP PIPELINE"
                                echo "====================================="

                                echo "Workspace    : ${WORKSPACE}"
                                echo "Cleanup Mode : ${params.CLEANUP_MODE}"
                            }
                        }
                    }
                }


                stage('MySQL Cleanup - Validate Cleanup Scripts') {

                    steps {

                        script {

                            runTrackedStage(
                                'mysql',
                                'cleanup',
                                'Validate Cleanup Scripts'
                            ) {

                                bat '''
                                    @echo off

                                    if not exist "%WORKSPACE%\\scripts\\powershell\\mysql\\cleanup\\cleanup_mysql.ps1" (
                                        echo ERROR: MySQL cleanup script not found
                                        exit /b 1
                                    )

                                    echo MySQL cleanup scripts validated successfully
                                '''
                            }
                        }
                    }
                }


                stage('MySQL Cleanup - Cleanup MySQL') {

                    steps {

                        script {

                            runTrackedStage(
                                'mysql',
                                'cleanup',
                                'Cleanup MySQL'
                            ) {

                                withEnv([
                                    "CLEANUP_MODE=${params.CLEANUP_MODE}"
                                ]) {

                                    bat '''
                                        @echo off

                                        echo.
                                        echo =====================================
                                        echo RUNNING MYSQL CLEANUP
                                        echo =====================================
                                        echo.

                                        call scripts\\batch\\mysql\\cleanup\\cleanup_mysql.bat

                                        if errorlevel 1 (
                                            echo.
                                            echo MYSQL CLEANUP FAILED
                                            exit /b 1
                                        )

                                        echo.
                                        echo MYSQL CLEANUP COMPLETED SUCCESSFULLY
                                    '''
                                }
                            }
                        }
                    }
                }
            }


            post {

                success {

                    echo "MYSQL WINDOWS CLEANUP PIPELINE SUCCESSFUL"
                }


                failure {

                    echo "MYSQL WINDOWS CLEANUP PIPELINE FAILED"
                }


                always {

                    script {

                        finalizeLoggingAndReporting(
                            'mysql',
                            'cleanup',
                            currentBuild.currentResult
                        )
                    }

                    echo "Cleanup Mode: ${params.CLEANUP_MODE}"
                    echo 'MYSQL CLEANUP PIPELINE COMPLETED'
                }
            }
        }



