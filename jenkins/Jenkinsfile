                            }
                        }
                    }
                }

                stage('MongoDB Setup - Validate Java Runtime') {
                    steps {
                        script {
                            runTrackedStage('mongodb', 'setup', 'Validate Java Runtime') {
                                bat 'scripts\\batch\\common\\validate_java_runtime.bat'
                            }
                        }
                    }
                }

                stage('MongoDB Setup - Install Tools') {
                    steps {
                        script {
                            runTrackedStage('mongodb', 'setup', 'Install Tools') {
                                bat 'scripts\\batch\\mongodb\\setup\\install_tools.bat'
                            }
                        }
                    }
                }

                stage('MongoDB Setup - Validate Tools') {
                    steps {
                        script {
                            runTrackedStage('mongodb', 'setup', 'Validate Tools') {
                                bat 'scripts\\batch\\mongodb\\setup\\validate_tools.bat'
                            }
                        }
                    }
                }

                stage('MongoDB Setup - Deploy MongoDB') {
                    steps {
                        script {
                            runTrackedStage('mongodb', 'setup', 'Deploy MongoDB') {
                                bat 'scripts\\batch\\mongodb\\setup\\run_terraform.bat'
                            }
                        }
                    }
                }

                stage('MongoDB Setup - Configure Global Mongosh') {

                    when {
                        expression {
                            return readFile('admin_status.txt').trim() == 'true'
                        }
                    }

                    steps {
                        script {
                            runTrackedStage('mongodb', 'setup', 'Configure Global Mongosh') {
                                echo 'Administrator privileges available.'
                                echo 'Configuring Global Mongosh command...'

                                bat 'scripts\\batch\\mongodb\\setup\\configure_global_mongosh.bat'
                            }
                        }
                    }
                }

                stage('MongoDB Setup - Configure MongoDB Service') {

                    when {
                        expression {
                            return readFile('admin_status.txt').trim() == 'true'
                        }
                    }

                    steps {
                        script {
                            runTrackedStage('mongodb', 'setup', 'Configure MongoDB Service') {
                                echo 'Administrator privileges available.'
                                echo 'Configuring MongoDB Windows Service...'

                                bat 'scripts\\batch\\mongodb\\setup\\configure_mongodb_service.bat'
                            }
                        }
                    }
                }

                stage('MongoDB Setup - Start MongoDB') {

                    when {
                        expression {
                            return readFile('admin_status.txt').trim() != 'true'
                        }
                    }

                    steps {
                        script {
                            runTrackedStage('mongodb', 'setup', 'Start MongoDB') {
                                echo 'Administrator privileges unavailable.'
                                echo 'Starting MongoDB in project-local mode...'

                                bat 'scripts\\batch\\mongodb\\setup\\start_mongodb.bat'
                            }
                        }
                    }
                }

                stage('MongoDB Setup - Validate MongoDB') {
                    steps {
                        script {
                            runTrackedStage('mongodb', 'setup', 'Validate MongoDB') {
                                bat 'scripts\\batch\\mongodb\\setup\\validate_mongodb.bat'
                            }
                        }
                    }
                }
            }

            post {

                success {

                    echo 'MONGODB SETUP SUCCESSFUL'

                    script {

                        def adminResult = readFile('admin_status.txt').trim()

                        if (adminResult == 'true') {
                            echo 'MongoDB Windows Service configured successfully.'
                            echo 'Global Mongosh configuration completed successfully.'
                        } else {
                            echo 'MongoDB configured successfully in project-local mode.'
                            echo 'Windows Service and Global Mongosh configuration were skipped because Administrator privileges were unavailable.'
                        }
                    }
                }

                failure {
                    echo 'MONGODB SETUP FAILED'
                }

                always {
                    script {
                        finalizeLoggingAndReporting('mongodb', 'setup', currentBuild.currentResult)
                    }
                    echo 'MONGODB SETUP PIPELINE COMPLETED'
                }
            }
        }


        /*
        ============================================================
        MONGODB LOAD
        ============================================================
        */

        stage('MongoDB Load') {

            agent { label 'windows-node' }

            when {
                allOf {
                    expression { params.DATABASE == 'MONGODB' }
                    expression { params.ACTION == 'LOAD' }
                }
            }

            stages {

                stage('MongoDB Load - Checkout SCM') {
                    steps {
                        checkout scm
                    }
                }

                stage('MongoDB Load - Initialize Logging') {
                    steps {
                        script {
                            initializeLogging('mongodb', 'load', 'windows')
                        }
                    }
                }

                stage('MongoDB Load - Validate Python Runtime') {
                    steps {
                        script {
                            runTrackedStage('mongodb', 'load', 'Validate Python Runtime') {
                                bat 'scripts\\batch\\common\\validate_python_runtime.bat'
                            }
                        }
                    }
                }

                stage('MongoDB Load - Validate Python Requirements') {
                    steps {
                        script {
                            runTrackedStage('mongodb', 'load', 'Validate Python Requirements') {
                                bat 'scripts\\batch\\mongodb\\setup\\validate_python_requirements.bat'
                            }
                        }
                    }
                }

                stage('MongoDB Load - Start MongoDB Service') {
                    steps {
                        script {
                            runTrackedStage('mongodb', 'load', 'Start MongoDB Service') {
                                bat 'scripts\\batch\\mongodb\\setup\\start_mongodb.bat'
                            }
                        }
                    }
                }

                stage('MongoDB Load - Validate MongoDB') {
                    steps {
                        script {
                            runTrackedStage('mongodb', 'load', 'Validate MongoDB') {
                                bat 'scripts\\batch\\mongodb\\setup\\validate_mongodb.bat'
                            }
                        }
                    }
                }

                stage('MongoDB Load - Download Dataset') {
                    steps {
                        script {
                            runTrackedStage('mongodb', 'load', 'Download Dataset') {
                                bat 'scripts\\batch\\common\\download_dataset.bat'
                            }
                        }
                    }
                }

                stage('MongoDB Load - Load Data') {
                    steps {
                        script {
                            runTrackedStage('mongodb', 'load', 'Load Data') {
                                bat 'scripts\\batch\\mongodb\\load\\load_data.bat'
                            }
                        }
                    }
                }

                stage('MongoDB Load - Validate Loaded Data') {
                    steps {
                        script {
                            runTrackedStage('mongodb', 'load', 'Validate Loaded Data') {
                                bat 'scripts\\batch\\mongodb\\load\\validate_loaded_data.bat'
                            }
                        }
                    }
                }
            }

            post {

                success {
                    echo 'MONGODB LOAD SUCCESSFUL'
                }

                failure {
                    echo 'MONGODB LOAD FAILED'
                }

                always {
                    script {
                        finalizeLoggingAndReporting('mongodb', 'load', currentBuild.currentResult)
                    }
                    echo 'MONGODB LOAD PIPELINE COMPLETED'
                }
            }
        }


        /*
        ============================================================
        MONGODB CLEANUP
        ============================================================
        */

        stage('MongoDB Cleanup') {

            agent { label 'windows-node' }

            when {
                allOf {
                    expression { params.DATABASE == 'MONGODB' }
                    expression { params.ACTION == 'CLEANUP' }
                }
            }

            environment {
                PIPELINE_TYPE = "MONGODB_WINDOWS_CLEANUP"
            }

            stages {

                stage('MongoDB Cleanup - Checkout SCM') {
                    steps {
                        checkout scm
                    }
                }

                stage('MongoDB Cleanup - Initialize Logging') {
                    steps {
                        script {
                            initializeLogging('mongodb', 'cleanup', 'windows')
                        }
                    }
                }

                stage('MongoDB Cleanup - Display Cleanup Configuration') {
                    steps {
                        script {
                            runTrackedStage('mongodb', 'cleanup', 'Display Cleanup Configuration') {
                                echo "======================================"
                                echo "MONGODB WINDOWS CLEANUP PIPELINE"
                                echo "======================================"
                                echo "Pipeline Type : ${env.PIPELINE_TYPE}"
                                echo "Cleanup Mode  : ${params.CLEANUP_MODE}"
                                echo "Workspace     : ${env.WORKSPACE}"
                                echo "======================================"
                            }
                        }
                    }
                }

                stage('MongoDB Cleanup - Validate Workspace') {
                    steps {
                        script {
                            runTrackedStage('mongodb', 'cleanup', 'Validate Workspace') {
                                bat '''
                                    @echo off

                                    echo.
                                    echo =====================================
                                    echo VALIDATING JENKINS WORKSPACE
                                    echo =====================================
                                    echo.

                                    if not exist "scripts\\batch\\mongodb\\cleanup\\mongodb_cleanup_pipeline.bat" (
                                        echo ERROR: MongoDB cleanup pipeline not found.
                                        exit /b 1
                                    )

                                    if not exist "config\\windows\\mongodb.conf" (
                                        echo ERROR: MongoDB configuration file not found.
                                        exit /b 1
                                    )

                                    if not exist "terraform\\mongodb" (
                                        echo ERROR: MongoDB Terraform directory not found.
                                        exit /b 1
                                    )

                                    echo MongoDB cleanup workspace validation successful.
                                '''
                            }
                        }
                    }
                }

                stage('MongoDB Cleanup - Run MongoDB Cleanup') {
                    steps {
                        script {
                            runTrackedStage('mongodb', 'cleanup', 'Run MongoDB Cleanup') {
                                withEnv(["CLEANUP_MODE=${params.CLEANUP_MODE}"]) {
                                    bat '''
                                        @echo off

                                        echo.
                                        echo =====================================
                                        echo RUNNING MONGODB WINDOWS CLEANUP
                                        echo =====================================
                                        echo.

                                        call scripts\\batch\\mongodb\\cleanup\\mongodb_cleanup_pipeline.bat

                                        if errorlevel 1 (
                                            echo.
                                            echo =====================================
                                            echo MONGODB CLEANUP FAILED
                                            echo =====================================
                                            echo.
                                            exit /b 1
                                        )

                                        echo.
                                        echo =====================================
                                        echo MONGODB CLEANUP COMPLETED
                                        echo =====================================
                                        echo.
                                    '''
                                }
                            }
                        }
                    }
                }
            }

            post {

                success {
                    echo "MONGODB WINDOWS CLEANUP SUCCESSFUL"
                }

                failure {
                    echo "MONGODB WINDOWS CLEANUP FAILED"
                }

                always {
                    script {
                        finalizeLoggingAndReporting('mongodb', 'cleanup', currentBuild.currentResult)
                    }
                    echo "Cleanup Mode: ${params.CLEANUP_MODE}"
                    echo 'MONGODB CLEANUP PIPELINE COMPLETED'
                }
            }
        }


        /*
        ============================================================
        POSTGRESQL SETUP
        ============================================================
        */

        stage('PostgreSQL Setup') {

