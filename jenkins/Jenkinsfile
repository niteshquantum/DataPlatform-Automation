                    steps {
                        script {
                            runTrackedStage('mysql', 'setup', 'Validate Environment') {
                                sh './scripts/bash/mysql/setup/validate_environment.sh'
                            }
                        }
                    }
                }
            }

            post {

                success {
                    echo 'MYSQL SETUP SUCCESSFUL'
                }

                failure {
                    echo 'MYSQL SETUP FAILED'
                }

                always {
                    script {
                        finalizeLoggingAndReporting('mysql', 'setup', currentBuild.currentResult)
                    }
                    echo 'MYSQL SETUP PIPELINE COMPLETED'
                }
            }
        }


