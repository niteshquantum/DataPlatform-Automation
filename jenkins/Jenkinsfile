        /*
        ============================================================
        MONGODB CLEANUP
        WINDOWS ONLY
        ============================================================
        */

        stage('MongoDB Cleanup') {

            agent {
                label 'windows-node'
            }


            when {

                allOf {

                    expression {
                        params.DATABASE == 'MONGODB'
                    }

                    expression {
                        params.ACTION == 'CLEANUP'
                    }
                }
            }


