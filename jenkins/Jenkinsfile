        /*
        ============================================================
        MONGODB CLEANUP (WINDOWS)
        ============================================================
        */


        stage('MongoDB Cleanup') {

            agent {
                label 'windows-node'
            }


            when {

                allOf {

                    expression {
                        params.DATABASE == 'MONGODB'
                    }

                    expression {
                        params.ACTION == 'CLEANUP'
                    }
                }
            }


            environment {
                PIPELINE_TYPE = "MONGODB_WINDOWS_CLEANUP"
            }


            stages {


                stage('MongoDB Cleanup - Checkout SCM') {

                    steps {

                        checkout scm
                    }
                }


                stage('MongoDB Cleanup - Initialize Logging') {

                    steps {

                        script {

                            initializeLogging(
                                'mongodb',
                                'cleanup',
                                'windows'
                            )
                        }
                    }
                }


                stage('MongoDB Cleanup - Display Cleanup Configuration') {

                    steps {

                        script {

                            runTrackedStage(
                                'mongodb',
                                'cleanup',
                                'Display Cleanup Configuration'
                            ) {

                                echo "======================================"
                                echo "MONGODB WINDOWS CLEANUP PIPELINE"
                                echo "======================================"
                                echo "Pipeline Type : ${env.PIPELINE_TYPE}"
                                echo "Cleanup Mode  : ${params.CLEANUP_MODE}"
                                echo "Workspace     : ${env.WORKSPACE}"
                                echo "======================================"
                            }
                        }
                    }
                }


                stage('MongoDB Cleanup - Validate Workspace') {

                    steps {

                        script {

                            runTrackedStage(
                                'mongodb',
                                'cleanup',
                                'Validate Workspace'
                            ) {

                                bat '''
                                    @echo off

                                    echo.
                                    echo =====================================
                                    echo VALIDATING JENKINS WORKSPACE
                                    echo =====================================
                                    echo.

                                    if not exist "scripts\\batch\\mongodb\\cleanup\\mongodb_cleanup_pipeline.bat" (
                                        echo ERROR: MongoDB cleanup pipeline not found.
                                        exit /b 1
                                    )

                                    if not exist "config\\windows\\mongodb.conf" (
                                        echo ERROR: MongoDB configuration file not found.
                                        exit /b 1
                                    )

                                    if not exist "terraform\\mongodb" (
                                        echo ERROR: MongoDB Terraform directory not found.
                                        exit /b 1
                                    )

                                    echo MongoDB cleanup workspace validation successful.
                                '''
                            }
                        }
                    }
                }


                stage('MongoDB Cleanup - Run MongoDB Cleanup') {

                    steps {

                        script {

                            runTrackedStage(
                                'mongodb',
                                'cleanup',
                                'Run MongoDB Cleanup'
                            ) {

                                withEnv([
                                    "CLEANUP_MODE=${params.CLEANUP_MODE}"
                                ]) {

                                    bat '''
                                        @echo off

                                        echo.
                                        echo =====================================
                                        echo RUNNING MONGODB WINDOWS CLEANUP
                                        echo =====================================
                                        echo.

                                        call scripts\\batch\\mongodb\\cleanup\\mongodb_cleanup_pipeline.bat

                                        if errorlevel 1 (
                                            echo.
                                            echo =====================================
                                            echo MONGODB CLEANUP FAILED
                                            echo =====================================
                                            echo.
                                            exit /b 1
                                        )

                                        echo.
                                        echo =====================================
                                        echo MONGODB CLEANUP COMPLETED
                                        echo =====================================
                                        echo.
                                    '''
                                }
                            }
                        }
                    }
                }
            }


            post {

                success {

                    echo "MONGODB WINDOWS CLEANUP SUCCESSFUL"
                }


                failure {

                    echo "MONGODB WINDOWS CLEANUP FAILED"
                }


                always {

                    script {

                        finalizeLoggingAndReporting(
                            'mongodb',
                            'cleanup',
                            currentBuild.currentResult
                        )
                    }

                    echo "Cleanup Mode: ${params.CLEANUP_MODE}"
                    echo 'MONGODB CLEANUP PIPELINE COMPLETED'
                }
            }
        }



        /*
        ============================================================
        POSTGRESQL SETUP (WINDOWS)
        ============================================================
        */


        stage('PostgreSQL Setup') {

            agent {
                label 'windows-node'
            }


            when {

                allOf {

                    expression {
                        params.DATABASE == 'POSTGRESQL'
                    }

                    expression {
                        params.ACTION == 'SETUP'
                    }

                    expression {
                        params.OS == 'WINDOWS'
                    }
                }
            }


