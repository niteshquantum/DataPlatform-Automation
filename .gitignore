# =====================================================
# Metadata
# Keep folder structure only
# =====================================================

metadata/*/*
!metadata/*/.gitkeep

# =====================================================
# Incoming
# Keep folder structure only
# =====================================================

incoming/*/*
!incoming/*/.gitkeep

# =====================================================
# Archive
# Keep folder structure only
# =====================================================

archive/*/*
!archive/*/.gitkeep

# =====================================================
# Failed
# Keep folder structure only
# =====================================================

failed/*/*
!failed/*/.gitkeep

# =====================================================
# Terraform
# Keep only Terraform configuration files
# =====================================================

terraform/*/*
!terraform/*/*.tf
!terraform/*/*.tfvars

# =====================================================
# Tools
# Keep folder structure only
# =====================================================

tools/*/*
!tools/*/.gitkeep

# =====================================================
# Liquibase
# Keep only required files
# =====================================================

# Ignore everything under Liquibase folders
liquibase/*/*

# Keep failed folder structure
!liquibase/failed/.gitkeep

# Keep required Liquibase configuration files
!liquibase/*/master.xml
!liquibase/*/liquibase.properties