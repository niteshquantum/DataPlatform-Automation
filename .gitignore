# =====================================================
# Databases (Generated Locally)
# =====================================================

databases/*
!databases/mssql/
databases/mssql/*
!databases/mssql/templates/
databases/mssql/templates/*
!databases/mssql/templates/ConfigurationFile.template.ini

# =====================================================
# Logs
# =====================================================

logs/
*.log

# =====================================================
# Reports & Assessment Outputs
# All files under outputs/assessments/ are generated at runtime.
# =====================================================

reports/
outputs/assessments/

# =====================================================
# Python
# =====================================================

**/__pycache__/
*.pyc
*.pyo
*.pyd

# =====================================================
# IDE
# =====================================================

.vscode/
.idea/

# =====================================================
# Operating System
# =====================================================

Thumbs.db
.DS_Store

# =====================================================
# Metadata
#
# schema_registry.json  = source input, KEEP (committed)
# All other JSON files  = generated at runtime, IGNORE
# =====================================================

metadata/**/object_registry.json
metadata/**/object_generation_report.json
metadata/**/object_validation_report.json
metadata/**/pipeline_log*.json
metadata/**/*.jsonl

# =====================================================
# Incoming / Archive / Failed
# Keep folder structure only
# =====================================================

incoming/*/*
archive/*/*
failed/*/*

# =====================================================
# Terraform
# Keep only Terraform source files
# =====================================================

terraform/*/*
!terraform/*/*.tf
!terraform/*/*.tfvars

# =====================================================
# Tools
# Drivers and binaries are downloaded at runtime.
# =====================================================

tools/*/*

# =====================================================
# Database Objects — Generated SQL
#
# objects/<db>/generated/  is fully auto-created by
# bootstrap_generator.py at runtime.
# objects/<db>/custom/     contains hand-authored SQL — KEEP.
# =====================================================

objects/**/generated/

# =====================================================
# Liquibase — Generated XML & runtime artifacts
#
# liquibase/<db>/objects/generated/  — auto-created by
#   bootstrap_generator.py at runtime — IGNORE.
#
# liquibase/<db>/objects/custom/     — hand-authored XML
#   objects — KEEP (committed).
#
# liquibase/<db>/master_objects.xml  — generated per-run
#   entry-point changelog — IGNORE.
#
# liquibase/<db>/master.xml          — hand-authored data
#   load changelog — KEEP (committed).
#
# liquibase/<db>/liquibase.properties — DB connection
#   config — KEEP (committed).
# =====================================================

# Ignore everything two levels deep by default
liquibase/*/*

# Keep root-level config and hand-authored data load changelog
!liquibase/*/liquibase.properties
!liquibase/*/master.xml

# Keep hand-authored custom object XML (all relational databases)
!liquibase/mysql/objects/
!liquibase/mysql/objects/custom/
!liquibase/mysql/objects/custom/**
!liquibase/postgresql/objects/
!liquibase/postgresql/objects/custom/
!liquibase/postgresql/objects/custom/**
!liquibase/mssql/objects/
!liquibase/mssql/objects/custom/
!liquibase/mssql/objects/custom/**

# Explicitly ignore generated XML contents and master_objects.xml
# (objects/generated/ dirs are auto-created, so no .gitkeep needed)
liquibase/**/objects/generated/
liquibase/**/master_objects.xml