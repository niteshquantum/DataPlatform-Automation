# =====================================================
# Databases (Generated Locally)
# =====================================================

databases/*
!databases/mssql/
databases/mssql/*
!databases/mssql/templates/
databases/mssql/templates/*
!databases/mssql/templates/ConfigurationFile.template.ini

# =====================================================
# Logs
# =====================================================

logs/
*.log

# =====================================================
# Reports & Assessment Outputs
# Generated at runtime — never commit.
# =====================================================

reports/

# Ignore all assessment output files but preserve .gitkeep
outputs/assessments/**/*.json
outputs/assessments/**/*.csv

# =====================================================
# Python
# =====================================================

**/__pycache__/
*.pyc
*.pyo
*.pyd

# =====================================================
# IDE
# =====================================================

.vscode/
.idea/

# =====================================================
# Operating System
# =====================================================

Thumbs.db
.DS_Store

# =====================================================
# Metadata — Generated and Runtime Outputs
#
# schema_registry.json   = generated from live DB scan
#                          dataset-specific — IGNORE
# object_*.json          = generated validation/registry
# pipeline_log*.json     = runtime log
# discovery/**           = runtime discovery outputs
#
# config/discovery/*.json = static source configs — TRACK
# =====================================================

metadata/**/schema_registry.json
metadata/**/object_registry.json
metadata/**/object_generation_report.json
metadata/**/object_validation_report.json
metadata/**/pipeline_log*.json
metadata/**/*.jsonl

# Ignore discovery output files but keep .gitkeep placeholders
metadata/discovery/**/*.json
metadata/discovery/**/*.csv

# metadata DB-level files (generated at runtime)
metadata/**/[0-9]*.json

# Keep .gitkeep placeholders in metadata dirs
!metadata/*/.gitkeep
!metadata/discovery/*/.gitkeep

# =====================================================
# Incoming / Archive / Failed
# =====================================================

incoming/*/*
archive/*/*
failed/*/*

# =====================================================
# Terraform
# =====================================================

terraform/*/*
!terraform/*/*.tf
!terraform/*/*.tfvars

# =====================================================
# Tools
# =====================================================

tools/*/*
!tools/*/.gitkeep

# Keep assessment folder .gitkeep placeholders
!outputs/assessments/.gitkeep
!outputs/assessments/*/.gitkeep

# =====================================================
# Database Objects — Custom SQL
#
# objects/<db>/custom/<category>/ holds dataset-specific
# hand-authored SQL. Not committed — only .gitkeep stays.
#
# objects/<db>/generated/ auto-created at runtime — IGNORE.
# =====================================================

objects/**/custom/**/*.sql
objects/**/generated/

# =====================================================
# Liquibase — Generated and Dataset-Specific Files
#
# IGNORED (dataset-specific/generated):
#   liquibase/<db>/[0-9]*.xml    = schema XML
#   liquibase/<db>/master.xml    = data master changelog
#   liquibase/master.xml         = top-level data master
#   liquibase/**/master_objects.xml = generated objects entry-point
#   liquibase/**/objects/custom/**/*.xml = dataset-specific object XML
#   liquibase/**/objects/generated/ = auto-created at runtime
#
# TRACKED (static source):
#   liquibase/<db>/liquibase.properties = DB connection config
#   **/.gitkeep = directory structure placeholders
# =====================================================

# Ignore everything two levels deep by default
liquibase/*/*

# Keep static DB connection config
!liquibase/*/liquibase.properties

# Ignore ALL dataset-specific schema changelogs and masters
liquibase/**/[0-9]*.xml
liquibase/**/master.xml
liquibase/**/master_objects.xml

# Ignore dataset-specific and generated object XML
liquibase/**/objects/custom/**/*.xml
liquibase/**/objects/generated/

# Allow folder structure through for .gitkeep
!liquibase/**/objects/
!liquibase/**/objects/custom/
!liquibase/**/objects/custom/*/
!liquibase/**/objects/generated/