# =====================================================
# Terraform
# =====================================================

**/.terraform/

*.tfstate
*.tfstate.*
*.tfplan

.terraform.lock.hcl

# =====================================================
# Databases (Generated Locally)
# =====================================================

databases/

# =====================================================
# Tools (Auto Downloaded)
# =====================================================

tools/

# =====================================================
# Logs
# =====================================================

logs/
*.log

# =====================================================
# Python
# =====================================================

**/__pycache__/
*.pyc
*.pyo
*.pyd

# =====================================================
# IDE
# =====================================================

.vscode/
.idea/

# =====================================================
# Operating System
# =====================================================

Thumbs.db
.DS_Store

# =====================================================
# Incoming / Archive / Failed
# =====================================================

incoming/mysql/*
!incoming/mysql/.gitkeep

archive/mysql/*
!archive/mysql/.gitkeep

failed/mysql/*
!failed/mysql/.gitkeep

incoming/postgresql/*
!incoming/postgresql/.gitkeep

archive/postgresql/*
!archive/postgresql/.gitkeep

failed/postgresql/*
!failed/postgresql/.gitkeep

incoming/mongodb/*
!incoming/mongodb/.gitkeep

archive/mongodb/*
!archive/mongodb/.gitkeep

failed/mongodb/*
!failed/mongodb/.gitkeep

incoming/mssql/*
!incoming/mssql/.gitkeep

archive/mssql/*
!archive/mssql/.gitkeep

failed/mssql/*
!failed/mssql/.gitkeep

# =====================================================
# Metadata (Generated)
# =====================================================

metadata/mysql/*
!metadata/mysql/.gitkeep
!metadata/mysql/schema_registry.json

metadata/postgresql/*
!metadata/postgresql/.gitkeep
!metadata/postgresql/schema_registry.json

metadata/mongodb/*
!metadata/mongodb/.gitkeep
!metadata/mongodb/schema_registry.json

metadata/mssql/*
!metadata/mssql/.gitkeep
!metadata/mssql/schema_registry.json